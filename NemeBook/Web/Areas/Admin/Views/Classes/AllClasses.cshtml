@model Web.ViewModels.PrincipalClassesViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Класове";
    ViewData["ActiveNav"] = "Classes";
}

<section class="nb-principal-content nb-classes-content" aria-label="Класове">
<div class="nb-classes-tabs" aria-label="Випуск">
    <span>Клас</span>
    @foreach (var gradeNumber in Model.GradeNumbers)
    {
        <a class="@(gradeNumber == Model.SelectedGrade ? "is-active" : null)"
           asp-area="Admin"
           asp-controller="Classes"
           asp-action="AllClasses"
           asp-route-grade="@gradeNumber">
            @gradeNumber
        </a>
    }
</div>

<section class="nb-classes-panel" aria-label="Паралелки">
    <div class="nb-classes-grid">
        @foreach (var schoolClass in Model.Classes)
        {
            <a class="nb-class-card"
               asp-area="Admin" asp-controller="ClassManagement"
               asp-action="Students"
               asp-route-classId="@schoolClass.Id">
                <strong>@schoolClass.Name</strong>
                <span class="nb-class-average @GetAverageClass(schoolClass.AverageGrade)">
                    @if (schoolClass.AverageGrade.HasValue)
                    {
                        @schoolClass.AverageGrade.Value.ToString("0.00")
                    }
                </span>
            </a>
        }
    </div>
</section>
</section>

@functions {
    private static string GetAverageClass(decimal? average)
    {
        if (!average.HasValue)
        {
            return "is-empty";
        }

        if (average.Value >= 5.50m)
        {
            return "is-high";
        }

        if (average.Value >= 4.50m)
        {
            return "is-medium";
        }

        return "is-low";
    }
}
