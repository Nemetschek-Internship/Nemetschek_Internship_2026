@model Web.ViewModels.ProfileImportUploadViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Импорт на профили";
    ViewData["ActiveNav"] = "Import";
}

<section class="nb-principal-content nb-import-admin-content" aria-label="Импорт на профили">
<section class="nb-principal-card nb-import-admin-card" aria-labelledby="profile-import-title">
    <div class="nb-import-admin-header">
        <span class="nb-import-admin-icon">
            <i class="bi bi-upload" aria-hidden="true"></i>
        </span>
        <div>
            <h2 id="profile-import-title">Импорт на профили</h2>
            <p>Качете Excel таблиците за ученици, учители и родители.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="nb-flash-message is-success">
            <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nb-flash-message is-error">
            <i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <form asp-action="Import" method="post" enctype="multipart/form-data" id="profileImportForm" novalidate>
        <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>

        <div class="nb-upload-grid">
            <div class="nb-upload-box">
                <label asp-for="StudentsFile" class="nb-upload-title">
                    <i class="bi bi-mortarboard-fill" aria-hidden="true"></i>
                    <span>Ученици</span>
                </label>
                <label class="nb-file-picker">
                    <input asp-for="StudentsFile" class="nb-file-input" type="file" accept=".xlsx,.xls" />
                    <span class="nb-file-button">Избери файл</span>
                    <span class="nb-file-name-display" data-empty-text="Няма избран файл">Няма избран файл</span>
                </label>
            </div>

            <div class="nb-upload-box">
                <label asp-for="TeachersFile" class="nb-upload-title">
                    <i class="bi bi-person-workspace" aria-hidden="true"></i>
                    <span>Учители</span>
                </label>
                <label class="nb-file-picker">
                    <input asp-for="TeachersFile" class="nb-file-input" type="file" accept=".xlsx,.xls" />
                    <span class="nb-file-button">Избери файл</span>
                    <span class="nb-file-name-display" data-empty-text="Няма избран файл">Няма избран файл</span>
                </label>
            </div>

            <div class="nb-upload-box">
                <label asp-for="ParentsFile" class="nb-upload-title">
                    <i class="bi bi-people-fill" aria-hidden="true"></i>
                    <span>Родители</span>
                </label>
                <label class="nb-file-picker">
                    <input asp-for="ParentsFile" class="nb-file-input" type="file" accept=".xlsx,.xls" />
                    <span class="nb-file-button">Избери файл</span>
                    <span class="nb-file-name-display" data-empty-text="Няма избран файл">Няма избран файл</span>
                </label>
            </div>
        </div>

        <button type="submit" class="nb-primary-action nb-import-submit" id="profileImportSubmit">
            <i class="bi bi-upload" aria-hidden="true"></i>
            Импортирай профили
        </button>
    </form>
</section>
</section>

<div class="nb-loading-overlay" id="profileImportLoading" role="status" aria-live="polite" aria-hidden="true">
<div class="nb-loading-panel">
<span class="nb-loading-spinner" aria-hidden="true"></span>
<strong>Импортът се обработва</strong>
<span>Моля, изчакайте. Профилите се добавят и имейлите се изпращат.</span>
</div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
document.querySelectorAll('.nb-file-picker').forEach(function (picker) {
const input = picker.querySelector('.nb-file-input');
const display = picker.querySelector('.nb-file-name-display');

input.addEventListener('change', function () {
display.textContent = input.files.length > 0
    ? input.files[0].name
    : display.dataset.emptyText;
});
});

const importForm = document.getElementById('profileImportForm');
const importSubmit = document.getElementById('profileImportSubmit');
const loadingOverlay = document.getElementById('profileImportLoading');

importForm.addEventListener('submit', function () {
loadingOverlay.classList.add('is-visible');
loadingOverlay.setAttribute('aria-hidden', 'false');
importSubmit.disabled = true;
importSubmit.innerHTML = '<span class="nb-button-spinner" aria-hidden="true"></span> Обработва се...';
});
</script>
}
