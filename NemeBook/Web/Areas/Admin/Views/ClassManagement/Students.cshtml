@model Web.ViewModels.PrincipalClassManagementViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = $"Клас {Model.ClassName}";
    ViewData["ActiveNav"] = "Classes";
}

<section class="nb-principal-content nb-class-management-content" aria-label="Управление на клас">
<div class="nb-class-management-tabs-row">
    <nav class="nb-class-management-tabs" aria-label="Секции на класа">
        <a class="@GetTabClass("Class")" asp-area="Admin" asp-controller="ClassManagement" asp-action="Students" asp-route-classId="@Model.ClassId">Клас</a>
        <a class="@GetTabClass("Subjects")" asp-area="Admin" asp-controller="ClassManagement" asp-action="Subjects" asp-route-classId="@Model.ClassId">Предмети</a>
        <a class="@GetTabClass("Schedule")" asp-area="Admin" asp-controller="ClassManagement" asp-action="Schedule" asp-route-classId="@Model.ClassId">Програма</a>
        <a class="@GetTabClass("Events")" asp-area="Admin" asp-controller="ClassManagement" asp-action="Events" asp-route-classId="@Model.ClassId">Събития</a>
    </nav>
    <a class="nb-principal-action-btn nb-class-back-btn" asp-area="Admin" asp-controller="Classes" asp-action="AllClasses" asp-route-grade="@GetGradeNumber(Model.ClassName)">
        <span>Всички класове</span>
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
    </a>
</div>

<section class="nb-class-students-panel" aria-labelledby="class-students-title">
    <div class="nb-class-section-header">
        <h2 id="class-students-title">Клас</h2>
    </div>

    <section class="nb-class-main-teacher" aria-label="Класен ръководител">
        <div class="nb-class-main-teacher-info">
            <span>Класен ръководител</span>
            <strong>@(Model.MainTeacherName ?? "Няма избран")</strong>
        </div>

        @if (Model.MainTeacherId.HasValue)
        {
            <form asp-area="Admin" asp-controller="ClassManagement"
                  asp-action="AssignMainTeacher"
                  method="post"
                  onsubmit="return confirm('Сигурни ли сте, че искате да премахнете класния ръководител?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classId" value="@Model.ClassId" />
                <button class="is-danger" type="submit">Премахни</button>
            </form>
        }
        else
        {
            <form class="nb-class-main-teacher-form"
                  asp-area="Admin" asp-controller="ClassManagement"
                  asp-action="AssignMainTeacher"
                  method="post"
                  data-teacher-search-url="@Url.Action("SearchAvailableMainTeacherMatches", "ClassManagement", new { area = "Admin" })">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classId" value="@Model.ClassId" />
                <input type="hidden" name="teacherId" class="nb-main-teacher-id" />

                <div class="nb-main-teacher-search">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <input class="nb-main-teacher-input"
                           type="search"
                           placeholder="Търси учител"
                           aria-label="Търси учител по име"
                           autocomplete="off" />
                    <div class="nb-main-teacher-dropdown" role="listbox" hidden></div>
                </div>

                <button class="nb-main-teacher-submit" type="submit" disabled>Назначи</button>
            </form>
        }
    </section>

    <div class="nb-class-section-header nb-class-students-heading">
        <h2>Ученици</h2>
        <span>@Model.Students.Count ученици</span>
    </div>

    <div class="nb-student-list">
        @foreach (var student in Model.Students)
        {
            <article class="nb-student-card">
                <div class="nb-student-main">
                    <span class="nb-student-number">@student.ClassNumber</span>
                    <strong>@student.FullName</strong>
                </div>

                <div class="nb-student-stats" aria-label="Статистика">
                    <span>
                        <small>Среден успех</small>
                        <strong>@FormatAverage(student.AverageGrade)</strong>
                    </span>
                    <span>
                        <small>Похвали</small>
                        <strong>@student.PraiseCount</strong>
                    </span>
                    <span>
                        <small>Забележки</small>
                        <strong>@student.RemarkCount</strong>
                    </span>
                    <span>
                        <small>Отсъствия и закъснения</small>
                        <strong>@student.AbsenceAndLatenessCount</strong>
                    </span>
                </div>

                <a class="nb-student-chat-btn"
                   asp-area=""
                   asp-controller="Chat"
                   asp-action="Index"
                   asp-route-targetUserId="@student.UserId"
                   aria-label="Чат с @student.FullName">
                    <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
                </a>
            </article>
        }
    </div>
</section>
</section>

@section Scripts {
<script>
(function () {
const form = document.querySelector('.nb-class-main-teacher-form');

if (!form) {
return;
}

const searchUrl = form.dataset.teacherSearchUrl;
const input = form.querySelector('.nb-main-teacher-input');
const teacherId = form.querySelector('.nb-main-teacher-id');
const dropdown = form.querySelector('.nb-main-teacher-dropdown');
const submit = form.querySelector('.nb-main-teacher-submit');
let abortController = null;

function closeDropdown() {
dropdown.hidden = true;
dropdown.innerHTML = '';
}

function clearSelection() {
teacherId.value = '';
submit.disabled = true;
}

function searchTeachers(clearSelectedTeacher) {
const query = input.value.trim();

if (clearSelectedTeacher !== false) {
    clearSelection();
}

if (abortController) {
    abortController.abort();
}

abortController = new AbortController();

fetch(
    searchUrl
    + '?classId=' + encodeURIComponent('@Model.ClassId')
    + '&query=' + encodeURIComponent(query),
    {
        headers: { 'Accept': 'application/json' },
        signal: abortController.signal
    })
    .then(function (response) {
        return response.ok ? response.json() : [];
    })
    .then(renderResults)
    .catch(function (error) {
        if (error.name !== 'AbortError') {
            closeDropdown();
        }
    });
}

function renderResults(results) {
dropdown.innerHTML = '';

if (results.length === 0) {
    const empty = document.createElement('span');
    empty.className = 'nb-main-teacher-empty';
    empty.textContent = 'Няма намерени учители';
    dropdown.appendChild(empty);
    dropdown.hidden = false;
    return;
}

results.forEach(function (teacher) {
    const button = document.createElement('button');
    button.type = 'button';
    button.setAttribute('role', 'option');
    button.textContent = teacher.fullName;

    button.addEventListener('click', function () {
        input.value = teacher.fullName;
        teacherId.value = teacher.id;
        submit.disabled = false;
        closeDropdown();
    });

    dropdown.appendChild(button);
});

dropdown.hidden = false;
}

input.addEventListener('input', function () {
searchTeachers(true);
});

input.addEventListener('focus', function () {
searchTeachers(false);
});

input.addEventListener('keydown', function (event) {
if (event.key === 'Escape') {
    closeDropdown();
    input.blur();
}
});

form.addEventListener('submit', function (event) {
if (!teacherId.value) {
    event.preventDefault();
}
});

document.addEventListener('click', function (event) {
if (!form.contains(event.target)) {
    closeDropdown();
}
});
}());
</script>
}

@functions {
    private string GetTabClass(string tab)
    {
        return Model.ActiveTab == tab ? "is-active" : string.Empty;
    }

    private static string FormatAverage(decimal? average)
    {
        return average.HasValue ? average.Value.ToString("0.00") : "-";
    }

    private static int GetGradeNumber(string className)
    {
        var digits = new string(className.TakeWhile(char.IsDigit).ToArray());
        return int.TryParse(digits, out var gradeNumber) ? gradeNumber : 1;
    }
}
