@model Web.ViewModels.PrincipalClassesViewModel

@{
    Layout = null;
    ViewData["Title"] = "Класове";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Класове - NemeBook</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="nb-principal-body">
    <div class="nb-principal-shell">
        <partial name="~/Views/Admin/Shared/_PrincipalSideNav.cshtml" model='@("Classes")' />

        <main class="nb-principal-main">
            <header class="nb-principal-topbar">
                <h1>Класове</h1>
                <partial name="_PrincipalStudentSearch" />
                <div class="nb-principal-top-actions">
                    <form asp-action="Logout" asp-area="" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button class="nb-principal-action-btn is-logout" type="submit">
                            <span>Изход</span>
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </header>

            <section class="nb-principal-content nb-classes-content" aria-label="Класове">
                <div class="nb-classes-tabs" aria-label="Випуск">
                    <span>Клас</span>
                    @foreach (var gradeNumber in Model.GradeNumbers)
                    {
                        <a class="@(gradeNumber == Model.SelectedGrade ? "is-active" : null)"
                          
                           asp-controller="Classes"
                           asp-action="AllClasses"
                           asp-route-grade="@gradeNumber">
                            @gradeNumber
                        </a>
                    }
                </div>

                <section class="nb-classes-panel" aria-label="Паралелки">
                    <div class="nb-classes-grid">
                        @foreach (var schoolClass in Model.Classes)
                        {
                            <a class="nb-class-card"
                               asp-controller="ClassManagement"
                               asp-action="Students"
                               asp-route-classId="@schoolClass.Id">
                                <strong>@schoolClass.Name</strong>
                                <span class="nb-class-average @GetAverageClass(schoolClass.AverageGrade)">
                                    @if (schoolClass.AverageGrade.HasValue)
                                    {
                                        @schoolClass.AverageGrade.Value.ToString("0.00")
                                    }
                                </span>
                            </a>
                        }
                    </div>
                </section>
            </section>
        </main>
    </div>
</body>
</html>

@functions {
    private static string GetAverageClass(decimal? average)
    {
        if (!average.HasValue)
        {
            return "is-empty";
        }

        if (average.Value >= 5.50m)
        {
            return "is-high";
        }

        if (average.Value >= 4.50m)
        {
            return "is-medium";
        }

        return "is-low";
    }
}

