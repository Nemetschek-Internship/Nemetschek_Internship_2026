@model Web.ViewModels.PrincipalHomeViewModel

@{
    var isPrincipal = User.IsInRole("Principal");

    Layout = isPrincipal ? null : "_Layout";
    ViewData["Title"] = "Начало";
}

@if (isPrincipal)
{
    <!DOCTYPE html>
    <html lang="bg">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Начало - NemeBook</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </head>
    <body class="nb-principal-body">
        <div class="nb-principal-shell">
            <partial name="~/Views/Admin/Shared/_PrincipalSideNav.cshtml" model='@("Dashboard")' />

            <main class="nb-principal-main">
                <header class="nb-principal-topbar">
                    <h1>Начало</h1>
                    <partial name="_PrincipalStudentSearch" />
                    <div class="nb-principal-top-actions">
                        <form asp-action="Logout" asp-area="" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            <button class="nb-principal-action-btn is-logout" type="submit">
                                <span>Изход</span>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            </button>
                        </form>
                    </div>
                </header>

                <section class="nb-principal-content" aria-label="Директорски панел">
                    <div class="nb-principal-summary">
                        <article class="nb-principal-average-card">
                            <span>Среден успех на училището</span>
                            @if (Model.SchoolAverageGrade.HasValue)
                            {
                                <strong>@Model.SchoolAverageGrade.Value.ToString("0.00")</strong>
                                <a asp-controller="Classes" asp-action="AllClasses">Виж всички класове <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
                                <span class="nb-principal-average-dot" aria-hidden="true"></span>
                            }
                        </article>

                        <article class="nb-principal-card nb-principal-insights">
                            <h2>Справки</h2>
                            @foreach (var report in Model.Reports)
                            {
                                <a class="nb-principal-insight-row @report.CssClass"
                                   asp-controller="Reports"
                                   asp-action="Index"
                                   asp-route-reportType="@report.ReportType">
                                    <span class="nb-principal-row-icon"></span>
                                    <span>@report.Label</span>
                                    <em>@report.Value</em>
                                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                </a>
                            }
                        </article>

                        <article class="nb-principal-card nb-principal-attention">
                            <h2>Изисква внимание</h2>
                            @foreach (var schoolClass in Model.ClassesNeedingAttention)
                            {
                                <div class="nb-principal-attention-row">
                                    <strong>@schoolClass.ClassName</strong>
                                    <span></span>
                                    <em class="@(schoolClass.AverageGrade < 4.50m ? "is-red" : null)">
                                        @schoolClass.AverageGrade.ToString("0.00")
                                    </em>
                                </div>
                            }
                        </article>
                    </div>

                    <section class="nb-principal-card nb-principal-chart-card">
                        <div class="nb-principal-chart-header">
                            <h2>Разпределение на оценките</h2>
                        </div>

                        <div class="nb-principal-chart" aria-label="Разпределение по оценки">
                            @foreach (var item in Model.GradeDistribution)
                            {
                                <div class="nb-principal-bar-item">
                                    <span class="nb-principal-bar is-grade-@item.Grade" style="height: @item.BarHeight.ToString()px"></span>
                                    <small>@GetGradeLabel(item.Grade) (@item.Count)</small>
                                </div>
                            }
                        </div>
                    </section>
                </section>
            </main>
        </div>
    </body>
    </html>
}
else
{
    <div class="nb-home">
        <section class="nb-home-panel">
            <h1 class="nb-home-title">Добре дошли в NemeBook</h1>
            <p class="nb-home-text">Следете оценки, съобщения и училищна информация от едно място.</p>
        </section>
    </div>
}

@functions {
    private static string GetGradeLabel(int grade)
    {
        return grade switch
        {
            2 => "Слаб 2",
            3 => "Среден 3",
            4 => "Добър 4",
            5 => "Много добър 5",
            6 => "Отличен 6",
            _ => grade.ToString(),
        };
    }
}

