@model Web.ViewModels.PrincipalClassManagementViewModel

@{
    Layout = null;
    ViewData["Title"] = $"Клас {Model.ClassName} - {Model.SectionTitle}";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Клас @Model.ClassName - NemeBook</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="nb-principal-body">
    <div class="nb-principal-shell">
        <partial name="~/Views/Admin/Shared/_PrincipalSideNav.cshtml" model='@("Classes")' />

        <main class="nb-principal-main">
            <header class="nb-principal-topbar">
                <h1>Клас @Model.ClassName</h1>
                <partial name="_PrincipalStudentSearch" />
                <div class="nb-principal-top-actions">
                    <form asp-action="Logout" asp-area="" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button class="nb-principal-action-btn is-logout" type="submit">
                            <span>Изход</span>
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </header>

            <section class="nb-principal-content nb-class-management-content" aria-label="Управление на клас">
                <div class="nb-class-management-tabs-row">
                    <nav class="nb-class-management-tabs" aria-label="Секции на класа">
                        <a class="@GetTabClass("Class")" asp-controller="ClassManagement" asp-action="Students" asp-route-classId="@Model.ClassId">Клас</a>
                        <a class="@GetTabClass("Subjects")" asp-controller="ClassManagement" asp-action="Subjects" asp-route-classId="@Model.ClassId">Предмети</a>
                        <a class="@GetTabClass("Schedule")" asp-controller="ClassManagement" asp-action="Schedule" asp-route-classId="@Model.ClassId">Програма</a>
                        <a class="@GetTabClass("Events")" asp-controller="ClassManagement" asp-action="Events" asp-route-classId="@Model.ClassId">Събития</a>
                    </nav>
                    <a class="nb-principal-action-btn nb-class-back-btn" asp-controller="Classes" asp-action="AllClasses" asp-route-grade="@GetGradeNumber(Model.ClassName)">
                        <span>Всички класове</span>
                        <i class="bi bi-arrow-left" aria-hidden="true"></i>
                    </a>
                </div>

                <section class="nb-class-students-panel nb-class-placeholder-panel" aria-labelledby="class-section-title">
                    <div class="nb-class-section-header">
                        <h2 id="class-section-title">@Model.SectionTitle</h2>
                    </div>
                    <div class="nb-class-placeholder">
                        <i class="bi bi-tools" aria-hidden="true"></i>
                        <span>@Model.EmptyMessage</span>
                    </div>
                </section>
            </section>
        </main>
    </div>
</body>
</html>

@functions {
    private string GetTabClass(string tab)
    {
        return Model.ActiveTab == tab ? "is-active" : string.Empty;
    }

    private static int GetGradeNumber(string className)
    {
        var digits = new string(className.TakeWhile(char.IsDigit).ToArray());
        return int.TryParse(digits, out var gradeNumber) ? gradeNumber : 1;
    }
}

