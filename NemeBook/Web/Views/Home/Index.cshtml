@{
    ViewData["Title"] = "Начало";
}

<style>
    .nb-home {
        min-height: calc(100vh - 160px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 0 48px;
    }

    .nb-home-panel {
        width: 100%;
        max-width: 760px;
        border: 1px solid #ebecef;
        border-radius: 20px;
        background: #ffffff;
        box-shadow: 0 12px 42px rgba(20, 25, 35, 0.1);
        padding: 28px;
        text-align: center;
    }

    .nb-home-title {
        margin: 0 0 8px;
        color: #25262b;
        font-size: 38px;
        font-weight: 800;
    }

    .nb-home-text {
        margin: 0 auto 20px;
        max-width: 560px;
        color: #737a85;
        font-size: 16px;
    }

    .nb-admin-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .nb-admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 11px;
        background: #f37021;
        color: #ffffff;
        font-weight: 700;
        text-decoration: none;
    }

    .nb-admin-btn:hover {
        background: #d95f16;
        color: #ffffff;
    }
</style>

<div class="nb-home">
    <section class="nb-home-panel">
        <h1 class="nb-home-title">Добре дошли в NemeBook</h1>
        <p class="nb-home-text">Управлявайте училищна информация, профили и комуникация от едно място.</p>

        @if (User.IsInRole("Principal"))
        {
            <div class="nb-admin-actions">
                <a class="nb-admin-btn" asp-controller="ProfileImport" asp-action="Index">
                    <i class="bi bi-file-earmark-spreadsheet"></i>
                    Импорт на профили
                </a>
            </div>
        }
    </section>
</div>
