@model Entities.ViewModels.Students.StudentHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Начало";
    ViewData["ActiveNav"] = "Home";
    ViewData["ShellUserName"] = Model.StudentName;
    ViewData["ShellUserMeta"] = Model.ClassName;
    ViewData["ShellUserInitials"] = Model.StudentInitials;

    var className = string.IsNullOrWhiteSpace(Model.ClassName) ? "Няма зададен клас" : Model.ClassName;
    var overallAverageText = Model.OverallAverage.ToString("0.00");
    var latestSubjects = Model.AcademicSubjects.Take(5).ToList();
}

@section TopbarActions {
    <button class="nb-notification-button"
            type="button"
            data-nb-modal-open="student-notifications-modal"
            data-notification-open
            aria-label="Известия"
            title="Известия">
        <i class="bi bi-bell-fill" aria-hidden="true"></i>
        <span class="nb-notification-badge" data-notification-count hidden>0</span>
    </button>
    <form asp-controller="Account" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
        <button class="nb-notification-button" type="submit" aria-label="Изход от профила" title="Изход">
            <i class="bi bi-box-arrow-right"></i>
        </button>
    </form>
    <span class="nb-student-avatar" aria-hidden="true">@Model.StudentInitials</span>
}

@section Styles {
<style>
    .nb-student-content {
        min-width: 0;
        padding: 28px 34px 44px;
    }

    .nb-student-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 22px;
    }

    .nb-student-header h2 {
        margin: 0;
        color: #242832;
        font-size: 24px;
        font-weight: 950;
        line-height: 1.12;
    }

    .nb-student-header p {
        margin: 6px 0 0;
        color: #81786f;
        font-size: 13px;
        font-weight: 800;
    }

    .nb-notification-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        min-width: 18px;
        height: 18px;
        display: inline-grid;
        place-items: center;
        padding: 0 5px;
        border: 2px solid #ffffff;
        border-radius: 999px;
        background: #f45d0a;
        color: #ffffff;
        font-size: 10px;
        font-weight: 950;
        line-height: 1;
    }

    .nb-student-top-grid {
        display: grid;
        grid-template-columns: minmax(280px, 1.05fr) minmax(360px, 1.55fr) minmax(240px, 0.9fr);
        gap: 18px;
        align-items: stretch;
    }

    .nb-summary-card,
    .nb-panel,
    .nb-action-card {
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
    }

    .nb-summary-card {
        min-height: 176px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 20px;
        padding: 24px;
        overflow: hidden;
        background: linear-gradient(135deg, #ff7826 0%, #f45d0a 62%, #ed5305 100%);
        color: #ffffff;
    }

    .nb-summary-title {
        margin: 0 0 10px;
        color: rgba(255, 255, 255, 0.94);
        font-size: 13px;
        font-weight: 900;
    }

    .nb-summary-card h3 {
        margin: 0;
        overflow: hidden;
        color: #ffffff;
        font-size: 22px;
        font-weight: 950;
        line-height: 1.15;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-summary-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    .nb-summary-meta span {
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.88);
        color: #e95b0c;
        font-size: 11px;
        font-weight: 900;
        white-space: nowrap;
    }

    .nb-average-ring {
        width: 78px;
        height: 78px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 14px 28px rgba(161, 61, 4, 0.18);
        color: #f45d0a;
        text-align: center;
    }

    .nb-average-ring strong {
        display: block;
        font-size: 18px;
        font-weight: 950;
        line-height: 1;
    }

    .nb-average-ring small {
        display: block;
        margin-top: 4px;
        font-size: 9px;
        font-weight: 950;
        line-height: 1;
    }

    .nb-panel {
        min-width: 0;
        padding: 18px;
    }

    .nb-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 14px;
    }

    .nb-panel-header h3 {
        margin: 0;
        color: #20232a;
        font-size: 14px;
        font-weight: 950;
    }

    .nb-panel-header span,
    .nb-panel-header a {
        color: #e95b0c;
        font-size: 12px;
        font-weight: 900;
        text-decoration: none;
        white-space: nowrap;
    }

    .nb-subject-progress-list,
    .nb-grade-list,
    .nb-schedule-list,
    .nb-modal-list {
        display: grid;
        gap: 9px;
    }

    .nb-subject-progress-row {
        min-width: 0;
        display: grid;
        grid-template-columns: 28px minmax(110px, 1fr) minmax(90px, 0.9fr) auto;
        align-items: center;
        gap: 10px;
    }

    .nb-subject-icon,
    .nb-grade-dot {
        width: 26px;
        height: 26px;
        display: grid;
        place-items: center;
        border-radius: 8px;
    }

    .nb-subject-icon::after,
    .nb-grade-dot::after {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    .is-purple { background: #eee3ff; color: #7447ff; }
    .is-blue { background: #dff0ff; color: #3177ff; }
    .is-green { background: #dff8e9; color: #20a95c; }

    .nb-subject-name,
    .nb-grade-name {
        min-width: 0;
        overflow: hidden;
        color: #333842;
        font-size: 13px;
        font-weight: 850;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-progress-track {
        height: 6px;
        overflow: hidden;
        border-radius: 999px;
        background: #e9e4dc;
    }

    .nb-progress-track span {
        height: 100%;
        display: block;
        border-radius: inherit;
    }

    .nb-progress-track .is-purple { background: #7447ff; }
    .nb-progress-track .is-blue { background: #3177ff; }
    .nb-progress-track .is-green { background: #20a95c; }

    .nb-score-chip,
    .nb-grade-chip {
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 3px 9px;
        border-radius: 999px;
        background: #ece7df;
        color: #81786f;
        font-size: 12px;
        font-weight: 900;
        white-space: nowrap;
    }

    .nb-score-chip {
        min-width: 44px;
        background: #fff1e6;
        color: #e95b0c;
    }

    .nb-action-stack {
        display: grid;
        gap: 12px;
    }

    .nb-action-card {
        min-height: 82px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px;
        color: inherit;
        font: inherit;
        text-align: left;
        cursor: pointer;
        transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nb-action-card:hover,
    .nb-action-card:focus-visible,
    .nb-grade-row:hover,
    .nb-grade-row:focus-visible,
    .nb-panel-header a:hover,
    .nb-panel-header a:focus-visible {
        border-color: #f97316;
        box-shadow: 0 12px 26px rgba(42, 35, 29, 0.08);
        outline: none;
    }

    .nb-action-card:active,
    .nb-grade-row:active {
        transform: translateY(1px);
    }

    .nb-action-card h3 {
        margin: 0;
        color: #1f232b;
        font-size: 13px;
        font-weight: 950;
    }

    .nb-action-card p {
        max-width: 170px;
        margin: 7px 0 0;
        overflow: hidden;
        color: #81786f;
        font-size: 11px;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-action-value {
        min-width: 38px;
        min-height: 28px;
        display: inline-grid;
        place-items: center;
        margin-top: 10px;
        padding: 2px 10px;
        border-radius: 999px;
        background: #ece7df;
        color: #8d867c;
        font-size: 18px;
        font-weight: 950;
        line-height: 1;
    }

    .nb-action-icon {
        width: 30px;
        height: 30px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #ffdcb8;
        color: #f46a16;
        font-size: 15px;
    }

    .nb-student-main-grid {
        display: grid;
        grid-template-columns: minmax(460px, 1.45fr) minmax(280px, 0.85fr);
        gap: 18px;
        margin-top: 18px;
    }

    .nb-grade-row {
        min-width: 0;
        min-height: 58px;
        display: grid;
        grid-template-columns: 26px minmax(0, 1fr) auto auto;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border: 1px solid transparent;
        border-radius: 8px;
        background: transparent;
        color: inherit;
        text-decoration: none;
        transition: background 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nb-grade-row:nth-child(odd) {
        background: #fffaf5;
    }

    .nb-grade-meta {
        min-width: 0;
        display: grid;
        gap: 3px;
    }

    .nb-grade-meta small {
        overflow: hidden;
        color: #9f978e;
        font-size: 11px;
        font-weight: 750;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-grade-chip-list {
        display: inline-flex;
        justify-content: flex-end;
        gap: 6px;
    }

    .nb-grade-chip {
        min-width: 24px;
        padding-inline: 7px;
    }

    .nb-grade-chip.is-good,
    .nb-modal-grade.is-good,
    .nb-status-good {
        background: #dff8e9;
        color: #16a34a;
    }

    .nb-grade-chip.is-mid,
    .nb-modal-grade.is-mid {
        background: #fff0d8;
        color: #e77817;
    }

    .nb-grade-chip.is-low,
    .nb-modal-grade.is-low,
    .nb-status-low {
        background: #ffe0dc;
        color: #e04434;
    }

    .nb-side-column {
        display: grid;
        align-content: start;
        gap: 18px;
    }

    .nb-schedule-item,
    .nb-recent-item {
        min-width: 0;
        min-height: 42px;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid #f3ece5;
    }

    .nb-schedule-item:last-child,
    .nb-recent-item:last-child {
        border-bottom: 0;
    }

    .nb-period-chip {
        min-width: 30px;
        min-height: 26px;
        display: inline-grid;
        place-items: center;
        border-radius: 999px;
        background: #fff1e6;
        color: #e95b0c;
        font-size: 11px;
        font-weight: 950;
    }

    .nb-schedule-name,
    .nb-recent-name {
        min-width: 0;
        overflow: hidden;
        color: #333842;
        font-size: 13px;
        font-weight: 850;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-schedule-time,
    .nb-recent-detail {
        color: #9f978e;
        font-size: 11px;
        font-weight: 800;
        white-space: nowrap;
    }

    .nb-empty-panel {
        min-height: 76px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #fbf7f2;
        color: #9f978e;
        font-size: 13px;
        font-weight: 850;
        text-align: center;
    }

    a.nb-empty-panel {
        color: #9f978e;
        text-decoration: none;
    }

    .nb-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 40;
        display: grid;
        place-items: center;
        padding: 24px;
        background: rgba(31, 35, 43, 0.42);
    }

    .nb-modal-backdrop[hidden] {
        display: none;
    }

    .nb-modal {
        width: min(760px, 100%);
        max-height: min(760px, calc(100vh - 48px));
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        overflow: hidden;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 30px 80px rgba(31, 35, 43, 0.28);
    }

    .nb-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 22px;
        border-bottom: 1px solid #eee7df;
    }

    .nb-modal-header h2 {
        margin: 0;
        color: #20232a;
        font-size: 17px;
        font-weight: 950;
    }

    .nb-modal-header p {
        margin: 4px 0 0;
        color: #9a938b;
        font-size: 12px;
        font-weight: 750;
    }

    .nb-modal-close {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border: 1px solid #f0ded0;
        border-radius: 50%;
        background: #fff8f1;
        color: #e95b0c;
        cursor: pointer;
    }

    .nb-modal-close:focus-visible {
        outline: 2px solid #ffb36d;
        outline-offset: 2px;
    }

    .nb-modal-body {
        min-height: 0;
        overflow: auto;
        padding: 18px 22px 22px;
    }

    .nb-modal-row {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 12px;
        padding: 12px;
        border: 1px solid #f0e8df;
        border-radius: 8px;
        background: #fffaf5;
    }

    .nb-modal-grade {
        min-width: 28px;
        min-height: 26px;
        display: inline-grid;
        place-items: center;
        padding: 2px 8px;
        border-radius: 999px;
        background: #eee7df;
        color: #8d867c;
        font-size: 11px;
        font-weight: 950;
    }

    .nb-modal-row-main {
        min-width: 0;
        display: grid;
        gap: 6px;
    }

    .nb-modal-row-main strong {
        color: #282c34;
        font-size: 13px;
        font-weight: 950;
    }

    .nb-modal-row-main p {
        margin: 0;
        color: #615b55;
        font-size: 13px;
        line-height: 1.45;
    }

    .nb-modal-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .nb-modal-meta span {
        min-height: 22px;
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 999px;
        background: #f0ebe4;
        color: #81786f;
        font-size: 11px;
        font-weight: 800;
    }

    .nb-modal-empty {
        min-height: 92px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #fbf7f2;
        color: #9f978e;
        font-size: 13px;
        font-weight: 850;
        text-align: center;
    }

    .nb-notification-modal-actions {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .nb-notification-clear {
        min-height: 32px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0 12px;
        border: 1px solid #f0ded0;
        border-radius: 999px;
        background: #fff8f1;
        color: #e95b0c;
        font: inherit;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
    }

    .nb-notification-clear:hover,
    .nb-notification-clear:focus-visible {
        border-color: #f97316;
        outline: none;
    }

    .nb-notification-clear:disabled {
        cursor: default;
        opacity: 0.5;
    }

    .nb-notification-list {
        display: grid;
        gap: 10px;
    }

    .nb-notification-item {
        width: 100%;
        min-height: 68px;
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr) auto;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border: 1px solid #f0e8df;
        border-radius: 8px;
        background: #fffaf5;
        color: inherit;
        font: inherit;
        text-align: left;
        cursor: pointer;
        transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nb-notification-item:hover,
    .nb-notification-item:focus-visible {
        border-color: #f97316;
        box-shadow: 0 12px 26px rgba(42, 35, 29, 0.08);
        outline: none;
    }

    .nb-notification-item:active {
        transform: translateY(1px);
    }

    .nb-notification-icon {
        width: 32px;
        height: 32px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #ffdcb8;
        color: #f46a16;
        font-size: 15px;
    }

    .nb-notification-copy {
        min-width: 0;
        display: grid;
        gap: 4px;
    }

    .nb-notification-copy strong {
        overflow: hidden;
        color: #282c34;
        font-size: 13px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-notification-copy span,
    .nb-notification-date {
        color: #9f978e;
        font-size: 11px;
        font-weight: 800;
        white-space: nowrap;
    }

    .nb-notification-date {
        justify-self: end;
    }

    body.nb-modal-open {
        overflow: hidden;
    }

    @@media (max-width: 1180px) {
        .nb-student-top-grid {
            grid-template-columns: minmax(280px, 1fr) minmax(360px, 1.25fr);
        }

        .nb-action-stack {
            grid-column: 1 / -1;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 920px) {
        .nb-student-header,
        .nb-student-top-grid,
        .nb-student-main-grid {
            grid-template-columns: 1fr;
        }

        .nb-student-header {
            align-items: flex-start;
        }

        .nb-action-stack {
            grid-column: auto;
        }
    }

    @@media (max-width: 640px) {
        .nb-student-content {
            padding: 20px 16px 34px;
        }

        .nb-student-header {
            display: grid;
        }

        .nb-student-header h2 {
            font-size: 21px;
        }

        .nb-summary-card {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .nb-average-ring {
            width: 68px;
            height: 68px;
        }

        .nb-subject-progress-row {
            grid-template-columns: 26px minmax(0, 1fr) auto;
        }

        .nb-progress-track {
            grid-column: 2 / -1;
        }

        .nb-action-stack {
            grid-template-columns: 1fr;
        }

        .nb-grade-row {
            grid-template-columns: 24px minmax(0, 1fr) auto;
        }

        .nb-grade-chip-list {
            grid-column: 2 / -1;
            justify-content: flex-start;
        }

        .nb-score-chip {
            grid-column: 3;
            grid-row: 1;
        }

        .nb-schedule-item,
        .nb-recent-item {
            grid-template-columns: auto minmax(0, 1fr);
        }

        .nb-schedule-time,
        .nb-recent-detail {
            grid-column: 2;
        }

        .nb-modal-backdrop {
            padding: 12px;
        }

        .nb-modal {
            max-height: calc(100vh - 24px);
        }

        .nb-modal-header,
        .nb-modal-body {
            padding-left: 16px;
            padding-right: 16px;
        }

        .nb-modal-row {
            grid-template-columns: 1fr;
        }

        .nb-notification-item {
            grid-template-columns: 32px minmax(0, 1fr);
        }

        .nb-notification-date {
            grid-column: 2;
            justify-self: start;
        }
    }
</style>
}

<section class="nb-student-content">
    <header class="nb-student-header">
        <div>
            <h2>@Model.StudentName</h2>
            <p>@className</p>
        </div>
    </header>

    <section class="nb-student-top-grid" aria-label="Обобщение за ученик">
        <article class="nb-summary-card">
            <div>
                <p class="nb-summary-title">Общ успех</p>
                <h3>@overallAverageText</h3>
                <div class="nb-summary-meta">
                    <span>@Model.GradeCount оценки общо</span>
                </div>
            </div>
            <div class="nb-average-ring" aria-label="Среден успех @overallAverageText">
                <div>
                    <strong>@overallAverageText</strong>
                    <small>СР.</small>
                </div>
            </div>
        </article>

        <article class="nb-panel">
            <div class="nb-panel-header">
                <h3>Среден успех по предмети</h3>
                <span>@Model.SubjectProgress.Count предмета</span>
            </div>

            @if (Model.SubjectProgress.Any())
            {
                <div class="nb-subject-progress-list">
                    @foreach (var subject in Model.SubjectProgress.Take(5))
                    {
                        <div class="nb-subject-progress-row">
                            <span class="nb-subject-icon @subject.AccentClass" aria-hidden="true"></span>
                            <span class="nb-subject-name" title="@subject.SubjectName">@subject.SubjectName</span>
                            <span class="nb-progress-track" aria-label="Прогрес @subject.ProgressPercent процента">
                                <span class="@subject.AccentClass" style="width: @subject.ProgressPercent%"></span>
                            </span>
                            <span class="nb-score-chip">@subject.Average.ToString("0.00")</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="nb-empty-panel">Все още няма данни по предмети.</div>
            }
        </article>

        <div class="nb-action-stack">
            <button class="nb-action-card" type="button" data-nb-modal-open="student-feedback-modal">
                <div>
                    <h3>Отзиви</h3>
                    <span class="nb-action-value">@Model.FeedbackSummary.Count</span>
                    <p title="@Model.FeedbackSummary.Detail">@Model.FeedbackSummary.Detail</p>
                </div>
                <span class="nb-action-icon" aria-hidden="true">
                    <i class="bi bi-chat-square-text-fill"></i>
                </span>
            </button>

            <button class="nb-action-card" type="button" data-nb-modal-open="student-absences-modal">
                <div>
                    <h3>Отсъствия</h3>
                    <span class="nb-action-value">@Model.AbsenceSummary.Count</span>
                    <p title="@Model.AbsenceSummary.Detail">@Model.AbsenceSummary.Detail</p>
                </div>
                <span class="nb-action-icon" aria-hidden="true">
                    <i class="bi bi-exclamation-circle-fill"></i>
                </span>
            </button>
        </div>
    </section>

    <section class="nb-student-main-grid">
        <article class="nb-panel">
            <div class="nb-panel-header">
                <h3>Оценки</h3>
                <a asp-controller="Student" asp-action="MyGrades">
                    Детайли <i class="bi bi-arrow-right-short" aria-hidden="true"></i>
                </a>
            </div>

            @if (latestSubjects.Any())
            {
                <div class="nb-grade-list">
                    @foreach (var subject in latestSubjects)
                    {
                        var latestGrades = subject.Grades.Take(3).ToList();

                        <a class="nb-grade-row" asp-controller="Student" asp-action="MyGrades">
                            <span class="nb-grade-dot" aria-hidden="true"></span>
                            <span class="nb-grade-meta">
                                <span class="nb-grade-name" title="@subject.SubjectName">@subject.SubjectName</span>
                                <small>@subject.GradeCount оценки</small>
                            </span>
                            <span class="nb-grade-chip-list" aria-label="Последни оценки по @subject.SubjectName">
                                @if (latestGrades.Any())
                                {
                                    @foreach (var grade in latestGrades)
                                    {
                                        var displayedGrade = GetDisplayedGrade(grade.Value);
                                        var gradeTone = displayedGrade >= 5 ? "is-good" : displayedGrade >= 4 ? "is-mid" : "is-low";
                                        <span class="nb-grade-chip @gradeTone">@displayedGrade</span>
                                    }
                                }
                                else
                                {
                                    <span class="nb-grade-chip">0</span>
                                }
                            </span>
                            <span class="nb-score-chip">@subject.Average.ToString("0.00")</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <a class="nb-empty-panel" asp-controller="Student" asp-action="MyGrades">
                    Няма добавени предмети. Средният успех е 0.00.
                </a>
            }
        </article>

        <div class="nb-side-column">
            <article class="nb-panel">
                <div class="nb-panel-header">
                    <h3>Днес</h3>
                    <span>Програма</span>
                </div>

                @if (Model.TodaysSchedule.Any())
                {
                    <div class="nb-schedule-list">
                        @foreach (var item in Model.TodaysSchedule)
                        {
                            <div class="nb-schedule-item">
                                <span class="nb-period-chip">@item.PeriodNumber</span>
                                <span class="nb-schedule-name" title="@item.SubjectName">@item.SubjectName</span>
                                <span class="nb-schedule-time">@item.TimeRange</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="nb-empty-panel">Няма програма за днес.</div>
                }
            </article>

            <article class="nb-panel">
                <div class="nb-panel-header">
                    <h3>Последни оценки</h3>
                    <span>@Model.RecentGrades.Count</span>
                </div>

                @if (Model.RecentGrades.Any())
                {
                    <div class="nb-grade-list">
                        @foreach (var item in Model.RecentGrades.Take(4))
                        {
                            <div class="nb-recent-item">
                                <span class="nb-grade-chip is-good">@item.Value</span>
                                <span class="nb-recent-name" title="@item.Title">@item.Title</span>
                                <span class="nb-recent-detail">@item.Detail</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="nb-empty-panel">Все още няма последни оценки.</div>
                }
            </article>
        </div>
    </section>
</section>

<form class="nb-notification-token-form" hidden>
    @Html.AntiForgeryToken()
</form>

<div class="nb-modal-backdrop" data-nb-modal="student-notifications-modal" hidden>
    <section class="nb-modal" role="dialog" aria-modal="true" aria-labelledby="student-notifications-title" tabindex="-1">
        <header class="nb-modal-header">
            <div>
                <h2 id="student-notifications-title">Известия</h2>
                <p data-notification-summary>Непрочетени известия</p>
            </div>
            <div class="nb-notification-modal-actions">
                <button class="nb-notification-clear" type="button" data-notification-clear-all>
                    <i class="bi bi-check2-all" aria-hidden="true"></i>
                    <span>Изчисти всички</span>
                </button>
                <button class="nb-modal-close" type="button" data-nb-modal-close aria-label="Затвори">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </header>
        <div class="nb-modal-body">
            <div class="nb-notification-list" data-notification-list></div>
            <div class="nb-modal-empty" data-notification-empty hidden>Няма нови известия.</div>
        </div>
    </section>
</div>

<div class="nb-modal-backdrop" data-nb-modal="student-feedback-modal" hidden>
    <section class="nb-modal" role="dialog" aria-modal="true" aria-labelledby="student-feedback-title" tabindex="-1">
        <header class="nb-modal-header">
            <div>
                <h2 id="student-feedback-title">Отзиви</h2>
                <p>@Model.FeedbackSummary.Count @Model.FeedbackSummary.Label</p>
            </div>
            <button class="nb-modal-close" type="button" data-nb-modal-close aria-label="Затвори">
                <i class="bi bi-x-lg"></i>
            </button>
        </header>
        <div class="nb-modal-body">
            @if (Model.Feedbacks.Any())
            {
                <div class="nb-modal-list">
                    @foreach (var feedback in Model.Feedbacks)
                    {
