@model Entities.ViewModels.Students.StudentHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Оценки";
    ViewData["ActiveNav"] = "Grades";
    ViewData["MainClass"] = "nb-academics-main";
    ViewData["ShellUserName"] = Model.StudentName;
    ViewData["ShellUserMeta"] = Model.ClassName;
    ViewData["ShellUserInitials"] = Model.StudentInitials;

    var gradeSubjects = Model.AcademicSubjects
        .OrderBy(subject => subject.SubjectName)
        .ToArray();
    var feedbackItems = Model.Feedbacks
        .Select((item, index) => new { Item = item, ModalId = $"feedback-detail-{index}" })
        .ToArray();
    var absenceItems = Model.Absences
        .Select((item, index) => new { Item = item, ModalId = $"absence-detail-{index}" })
        .ToArray();
    var feedbackSubjects = feedbackItems
        .Select(item => item.Item.SubjectName)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToArray();
    var absenceSubjects = absenceItems
        .Select(item => item.Item.SubjectName)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToArray();
}

@section Styles {
<style>
    .nb-academics-main {
        min-width: 0;
        background: #fbf3ec;
    }
    .nb-academics-page {
        display: grid;
        gap: 18px;
        padding: 28px 34px 44px;
    }
    .nb-academics-header,
    .nb-academics-panel {
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
    }
    .nb-academics-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 18px;
        padding: 20px;
    }
    .nb-academics-title h1 {
        margin: 0;
        color: #1f232b;
        font-size: 22px;
        font-weight: 950;
    }
    .nb-academics-title p {
        margin: 5px 0 0;
        color: #8f887f;
        font-size: 12px;
        font-weight: 850;
    }
    .nb-academics-tabs {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 5px;
        border-radius: 8px;
        background: #fbf7f2;
    }
    .nb-tab-btn {
        min-height: 34px;
        border: 0;
        border-radius: 7px;
        background: transparent;
        color: #6f6962;
        font: inherit;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
        padding: 0 12px;
    }
    .nb-tab-btn.is-active {
        background: #ffe4c2;
        color: #f97316;
    }
    .nb-tab-panel[hidden] {
        display: none;
    }
    .nb-academics-panel {
        overflow: hidden;
    }
    .nb-panel-head,
    .nb-subject-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(240px, auto);
        align-items: center;
        gap: 14px;
    }
    .nb-panel-head {
        padding: 16px 18px;
        border-bottom: 1px solid #f0e8df;
    }
    .nb-panel-head h2 {
        margin: 0;
        color: #20232a;
        font-size: 16px;
        font-weight: 950;
    }
    .nb-panel-head span {
        justify-self: end;
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
    }
    .nb-subject-list {
        display: grid;
    }
    .nb-subject-row {
        min-height: 62px;
        padding: 13px 18px;
        border-bottom: 1px solid #f5eee7;
    }
    .nb-subject-row:last-child {
        border-bottom: 0;
    }
    .nb-subject-name {
        min-width: 0;
        display: grid;
        gap: 4px;
    }
    .nb-subject-name strong {
        overflow: hidden;
        color: #20232a;
        font-size: 14px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-subject-name span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
    }
    .nb-grade-chip-list,
    .nb-count-list {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
    }
    .nb-grade-chip,
    .nb-popup-grade {
        width: 38px;
        height: 38px;
        display: inline-grid;
        place-items: center;
        border: 0;
        border-radius: 50%;
        background: #fff0d8;
        color: #e77817;
        font: inherit;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
    }
    .nb-grade-chip.is-good,
    .nb-popup-grade.is-good,
    .nb-status.is-good {
        background: #dff8e9;
        color: #16a34a;
    }
    .nb-grade-chip.is-low,
    .nb-popup-grade.is-low,
    .nb-status.is-low {
        background: #ffe0dc;
        color: #e04434;
    }
    .nb-grade-chip:hover,
    .nb-count-btn:hover,
    .nb-detail-list-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(42, 35, 29, 0.1);
    }
    .nb-count-btn,
    .nb-count-empty {
        min-height: 34px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border: 0;
        border-radius: 8px;
        background: #fbf7f2;
        color: #6f6962;
        font: inherit;
        font-size: 11px;
        font-weight: 950;
        padding: 0 10px;
    }
    .nb-count-btn {
        cursor: pointer;
        transition: transform 0.16s ease, box-shadow 0.16s ease;
    }
    .nb-count-empty {
        opacity: 0.62;
    }
    .nb-count-btn.is-good {
        background: #dff8e9;
        color: #159953;
    }
    .nb-count-btn.is-low {
        background: #ffe0dc;
        color: #c23329;
    }
    .nb-count-btn.is-warn {
        background: #fff0d8;
        color: #c76500;
    }
    .nb-empty-state {
        min-height: 160px;
        display: grid;
        place-items: center;
        padding: 18px;
        color: #8f887f;
        font-size: 13px;
        font-weight: 850;
        text-align: center;
    }
    .nb-popup-backdrop {
        position: fixed;
        inset: 0;
        z-index: 70;
        display: grid;
        place-items: center;
        padding: 24px;
        background: rgba(31, 35, 43, 0.42);
    }
    .nb-popup-backdrop[hidden] {
        display: none;
    }
    .nb-popup {
        width: min(520px, 100%);
        max-height: min(82vh, 720px);
        overflow: hidden;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 30px 80px rgba(31, 35, 43, 0.28);
    }
    .nb-popup-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border-bottom: 1px solid #eee7df;
    }
    .nb-popup-header h3 {
        margin: 0;
        color: #20232a;
        font-size: 16px;
        font-weight: 900;
    }
    .nb-popup-header p {
        margin: 3px 0 0;
        color: #9a938b;
        font-size: 12px;
        font-weight: 750;
    }
    .nb-popup-close {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border: 1px solid #f0ded0;
        border-radius: 50%;
        background: #fff8f1;
        color: #e95b0c;
        cursor: pointer;
    }
    .nb-popup-body {
        min-height: 0;
        overflow-y: auto;
        display: grid;
        gap: 12px;
        padding: 18px 20px 20px;
    }
    .nb-detail-grid {
        display: grid;
        gap: 9px;
    }
    .nb-detail-row,
    .nb-detail-list-btn {
        min-height: 38px;
        display: grid;
        grid-template-columns: 100px minmax(0, 1fr);
        align-items: center;
        gap: 12px;
        padding: 9px 10px;
        border-radius: 8px;
        background: #fbf7f2;
    }
    .nb-detail-row span:first-child {
        color: #8d867c;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-detail-row span:last-child {
        min-width: 0;
        overflow-wrap: anywhere;
        color: #242832;
        font-size: 13px;
        font-weight: 850;
    }
    .nb-detail-list {
        display: grid;
        gap: 9px;
    }
    .nb-detail-list-btn {
        width: 100%;
        grid-template-columns: minmax(0, 1fr) auto;
        border: 0;
        color: inherit;
        font: inherit;
        text-align: left;
        cursor: pointer;
        transition: transform 0.16s ease, box-shadow 0.16s ease;
    }
    .nb-detail-list-btn strong {
        overflow: hidden;
        color: #242832;
        font-size: 13px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-detail-list-btn span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
        white-space: nowrap;
    }
    .nb-status {
        width: fit-content;
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        background: #f0ebe4;
        color: #81786f;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-popup-comment {
        margin: 0;
        padding: 12px;
        border-radius: 8px;
        background: #fbf7f2;
        color: #514b45;
        font-size: 13px;
        line-height: 1.45;
    }
    body.nb-popup-open {
        overflow: hidden;
    }
    @@media (max-width: 760px) {
        .nb-academics-page {
            padding: 18px;
        }
        .nb-academics-header,
        .nb-panel-head,
        .nb-subject-row {
            grid-template-columns: 1fr;
        }
        .nb-panel-head span,
        .nb-grade-chip-list,
        .nb-count-list {
            justify-self: start;
            justify-content: flex-start;
        }
        .nb-popup-backdrop {
            padding: 12px;
        }
        .nb-detail-row {
            grid-template-columns: 1fr;
            gap: 4px;
        }
    }
</style>
}

<section class="nb-academics-page">
    <header class="nb-academics-header">
        <div class="nb-academics-title">
            <h1>Учебни записи</h1>
            <p>Клас @Model.ClassName · среден успех @Model.OverallAverage.ToString("0.00")</p>
        </div>

        <nav class="nb-academics-tabs" aria-label="Учебни раздели">
            <button class="nb-tab-btn is-active" type="button" data-nb-tab="grades">Оценки</button>
            <button class="nb-tab-btn" type="button" data-nb-tab="feedbacks">Отзиви</button>
            <button class="nb-tab-btn" type="button" data-nb-tab="absences">Отсъствия</button>
        </nav>
    </header>

    <article class="nb-academics-panel nb-tab-panel" data-nb-tab-panel="grades">
        <header class="nb-panel-head">
            <h2>Оценки по предмети</h2>
            <span>@Model.GradeCount оценки</span>
        </header>

        @if (gradeSubjects.Length == 0)
        {
            <div class="nb-empty-state">Все още няма добавени предмети.</div>
        }
        else
        {
            <div class="nb-subject-list">
                @foreach (var subject in gradeSubjects)
                {
                    <section class="nb-subject-row">
                        <div class="nb-subject-name">
                            <strong>@subject.SubjectName</strong>
                            <span>Средно @(subject.GradeCount == 0 ? "-" : subject.Average.ToString("0.00"))</span>
                        </div>
                        <div class="nb-grade-chip-list" aria-label="Оценки по @subject.SubjectName">
                            @if (subject.Grades.Any())
                            {
                                @foreach (var grade in subject.Grades.OrderByDescending(grade => grade.Date))
                                {
                                    var displayedGrade = GetDisplayedGrade(grade.Value);
                                    var gradeTone = displayedGrade >= 5 ? "is-good" : displayedGrade >= 4 ? string.Empty : "is-low";
                                    var modalId = $"grade-popup-{grade.Id:N}";
                                    var gradeTitle = grade.Date.ToString("dd.MM.yyyy");

                                    <button class="nb-grade-chip @gradeTone"
                                            type="button"
                                            data-nb-popup-open="@modalId"
                                            title="@gradeTitle"
                                            aria-label="Отвори оценка @displayedGrade по @subject.SubjectName">
                                        @displayedGrade
                                    </button>
                                }
                            }
                            else
                            {
                                <span class="nb-count-empty">Няма оценки</span>
                            }
                        </div>
                    </section>
                }
            </div>
        }
    </article>

    <article class="nb-academics-panel nb-tab-panel" data-nb-tab-panel="feedbacks" hidden>
        <header class="nb-panel-head">
            <h2>Отзиви по предмети</h2>
            <span>@Model.Feedbacks.Count отзиви</span>
        </header>

        @if (feedbackSubjects.Length == 0)
        {
            <div class="nb-empty-state">Все още няма въведени отзиви.</div>
        }
        else
        {
            <div class="nb-subject-list">
                @foreach (var subject in feedbackSubjects)
                {
                    var positive = feedbackItems
                        .Where(item => string.Equals(item.Item.SubjectName, subject, StringComparison.OrdinalIgnoreCase) && IsPositiveFeedback(item.Item.Type))
                        .ToArray();
                    var negative = feedbackItems
                        .Where(item => string.Equals(item.Item.SubjectName, subject, StringComparison.OrdinalIgnoreCase) && !IsPositiveFeedback(item.Item.Type))
                        .ToArray();
                    var positiveModalId = $"feedback-positive-{Math.Abs(subject.GetHashCode())}";
                    var negativeModalId = $"feedback-negative-{Math.Abs(subject.GetHashCode())}";

                    <section class="nb-subject-row">
                        <div class="nb-subject-name">
                            <strong>@subject</strong>
                            <span>@(positive.Length + negative.Length) отзиви</span>
                        </div>
                        <div class="nb-count-list">
                            @if (positive.Length > 0)
                            {
                                <button class="nb-count-btn is-good" type="button" data-nb-popup-open="@positiveModalId">
                                    Положителни <strong>@positive.Length</strong>
                                </button>
                            }
                            else
                            {
                                <span class="nb-count-empty">Положителни 0</span>
                            }
                            @if (negative.Length > 0)
                            {
                                <button class="nb-count-btn is-low" type="button" data-nb-popup-open="@negativeModalId">
                                    Отрицателни <strong>@negative.Length</strong>
                                </button>
                            }
                            else
                            {
                                <span class="nb-count-empty">Отрицателни 0</span>
                            }
                        </div>
                    </section>

                    @if (positive.Length > 0)
                    {
                        <div class="nb-popup-backdrop" data-nb-popup="@positiveModalId" hidden>
                            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{positiveModalId}-title")" tabindex="-1">
                                <header class="nb-popup-header">
                                    <div>
                                        <h3 id="@($"{positiveModalId}-title")">Положителни отзиви</h3>
                                        <p>@subject · @positive.Length записи</p>
                                    </div>
                                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </header>
                                <div class="nb-popup-body">
                                    <div class="nb-detail-list">
                                        @foreach (var feedback in positive)
                                        {
                                            <button class="nb-detail-list-btn" type="button" data-nb-popup-open="@feedback.ModalId">
                                                <strong>@feedback.Item.Comment</strong>
                                                <span>@feedback.Item.Date.ToString("dd.MM.yyyy")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </section>
                        </div>
                    }

                    @if (negative.Length > 0)
                    {
                        <div class="nb-popup-backdrop" data-nb-popup="@negativeModalId" hidden>
                            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{negativeModalId}-title")" tabindex="-1">
                                <header class="nb-popup-header">
                                    <div>
                                        <h3 id="@($"{negativeModalId}-title")">Отрицателни отзиви</h3>
                                        <p>@subject · @negative.Length записи</p>
                                    </div>
                                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </header>
                                <div class="nb-popup-body">
                                    <div class="nb-detail-list">
                                        @foreach (var feedback in negative)
                                        {
                                            <button class="nb-detail-list-btn" type="button" data-nb-popup-open="@feedback.ModalId">
                                                <strong>@feedback.Item.Comment</strong>
                                                <span>@feedback.Item.Date.ToString("dd.MM.yyyy")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </section>
                        </div>
                    }
                }
            </div>
        }
    </article>

    <article class="nb-academics-panel nb-tab-panel" data-nb-tab-panel="absences" hidden>
        <header class="nb-panel-head">
            <h2>Отсъствия по предмети</h2>
            <span>@Model.Absences.Count записи</span>
        </header>

        @if (absenceSubjects.Length == 0)
        {
            <div class="nb-empty-state">Все още няма въведени отсъствия.</div>
        }
        else
        {
            <div class="nb-subject-list">
                @foreach (var subject in absenceSubjects)
                {
                    var subjectAbsences = absenceItems
                        .Where(item => string.Equals(item.Item.SubjectName, subject, StringComparison.OrdinalIgnoreCase))
                        .ToArray();
                    var excused = subjectAbsences
                        .Where(item => IsExcused(item.Item.Status) && !IsLateness(item.Item.Type))
                        .ToArray();
                    var lateness = subjectAbsences
                        .Where(item => IsLateness(item.Item.Type))
                        .ToArray();
                    var absences = subjectAbsences
                        .Where(item => !IsLateness(item.Item.Type))
                        .ToArray();
                    var baseId = Math.Abs(subject.GetHashCode());
                    var excusedModalId = $"absence-excused-{baseId}";
                    var latenessModalId = $"absence-lateness-{baseId}";
                    var absencesModalId = $"absence-all-{baseId}";

                    <section class="nb-subject-row">
                        <div class="nb-subject-name">
                            <strong>@subject</strong>
                            <span>@subjectAbsences.Length записи</span>
                        </div>
                        <div class="nb-count-list">
                            @if (excused.Length > 0)
                            {
                                <button class="nb-count-btn is-good" type="button" data-nb-popup-open="@excusedModalId">
                                    Извинени <strong>@excused.Length</strong>
                                </button>
                            }
                            else
                            {
                                <span class="nb-count-empty">Извинени 0</span>
                            }
                            @if (lateness.Length > 0)
                            {
                                <button class="nb-count-btn is-warn" type="button" data-nb-popup-open="@latenessModalId">
                                    Закъснения <strong>@lateness.Length</strong>
                                </button>
                            }
                            else
                            {
                                <span class="nb-count-empty">Закъснения 0</span>
                            }
                            @if (absences.Length > 0)
                            {
                                <button class="nb-count-btn" type="button" data-nb-popup-open="@absencesModalId">
                                    Отсъствия <strong>@absences.Length</strong>
                                </button>
                            }
                            else
                            {
                                <span class="nb-count-empty">Отсъствия 0</span>
                            }
                        </div>
                    </section>

                    @if (excused.Length > 0)
                    {
                        <div class="nb-popup-backdrop" data-nb-popup="@excusedModalId" hidden>
                            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{excusedModalId}-title")" tabindex="-1">
                                <header class="nb-popup-header">
                                    <div>
                                        <h3 id="@($"{excusedModalId}-title")">Извинени отсъствия</h3>
                                        <p>@subject · @excused.Length записи</p>
                                    </div>
                                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </header>
                                <div class="nb-popup-body">
                                    <div class="nb-detail-list">
                                        @foreach (var absence in excused)
                                        {
                                            <button class="nb-detail-list-btn" type="button" data-nb-popup-open="@absence.ModalId">
                                                <strong>@absence.Item.Type · @absence.Item.LessonNumber час</strong>
                                                <span>@absence.Item.Date.ToString("dd.MM.yyyy")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </section>
                        </div>
                    }

                    @if (lateness.Length > 0)
                    {
                        <div class="nb-popup-backdrop" data-nb-popup="@latenessModalId" hidden>
                            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{latenessModalId}-title")" tabindex="-1">
                                <header class="nb-popup-header">
                                    <div>
                                        <h3 id="@($"{latenessModalId}-title")">Закъснения</h3>
                                        <p>@subject · @lateness.Length записи</p>
                                    </div>
                                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </header>
                                <div class="nb-popup-body">
                                    <div class="nb-detail-list">
                                        @foreach (var absence in lateness)
                                        {
                                            <button class="nb-detail-list-btn" type="button" data-nb-popup-open="@absence.ModalId">
                                                <strong>@absence.Item.Type · @absence.Item.LessonNumber час</strong>
                                                <span>@absence.Item.Date.ToString("dd.MM.yyyy")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </section>
                        </div>
                    }

                    @if (absences.Length > 0)
                    {
                        <div class="nb-popup-backdrop" data-nb-popup="@absencesModalId" hidden>
                            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{absencesModalId}-title")" tabindex="-1">
                                <header class="nb-popup-header">
                                    <div>
                                        <h3 id="@($"{absencesModalId}-title")">Всички отсъствия</h3>
                                        <p>@subject · @absences.Length записи</p>
                                    </div>
                                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </header>
                                <div class="nb-popup-body">
                                    <div class="nb-detail-list">
                                        @foreach (var absence in absences)
                                        {
                                            <button class="nb-detail-list-btn" type="button" data-nb-popup-open="@absence.ModalId">
                                                <strong>@absence.Item.Type · @absence.Item.LessonNumber час</strong>
                                                <span>@absence.Item.Date.ToString("dd.MM.yyyy")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </section>
                        </div>
                    }
                }
            </div>
        }
    </article>
</section>

