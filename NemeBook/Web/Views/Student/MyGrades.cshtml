@section Scripts {
<script>
(() => {
const tabButtons = document.querySelectorAll("[data-nb-tab]");
const tabPanels = document.querySelectorAll("[data-nb-tab-panel]");
const triggers = document.querySelectorAll("[data-nb-popup-open]");
const popups = document.querySelectorAll("[data-nb-popup]");
let activeTrigger = null;

tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
        tabButtons.forEach((current) => current.classList.toggle("is-active", current === button));
        tabPanels.forEach((panel) => {
            panel.hidden = panel.dataset.nbTabPanel !== button.dataset.nbTab;
        });
    });
});

const closePopup = (popup) => {
    if (!popup) {
        return;
    }

    popup.hidden = true;

    if (!document.querySelector("[data-nb-popup]:not([hidden])")) {
        document.body.classList.remove("nb-popup-open");
    }

    if (activeTrigger) {
        activeTrigger.focus();
        activeTrigger = null;
    }
};

const openPopup = (id, trigger) => {
    const popup = document.querySelector(`[data-nb-popup="${id}"]`);
    if (!popup) {
        return;
    }

    activeTrigger = trigger;
    popup.hidden = false;
    document.body.classList.add("nb-popup-open");
    popup.querySelector(".nb-popup")?.focus();
};

triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
        openPopup(trigger.dataset.nbPopupOpen, trigger);
    });
});

popups.forEach((popup) => {
    popup.addEventListener("click", (event) => {
        if (event.target === popup || event.target.closest("[data-nb-popup-close]")) {
            closePopup(popup);
        }
    });
});

document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
        closePopup(Array.from(document.querySelectorAll("[data-nb-popup]:not([hidden])")).at(-1));
    }
});
})();
</script>
}

@functions {
    private static int GetDisplayedGrade(decimal value)
    {
        if (value < 3)
        {
            return 2;
        }

        return Math.Clamp((int)Math.Floor(value + 0.5m), 3, 6);
    }

    private static bool IsPositiveFeedback(string type)
    {
        return type.Contains("похвал", StringComparison.OrdinalIgnoreCase) ||
            type.Contains("positive", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsLateness(string type)
    {
        return type.Contains("закъс", StringComparison.OrdinalIgnoreCase) ||
            type.Contains("late", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsExcused(string status)
    {
        return !status.Contains("неуваж", StringComparison.OrdinalIgnoreCase) &&
            (status.Contains("уваж", StringComparison.OrdinalIgnoreCase) ||
             status.Contains("excused", StringComparison.OrdinalIgnoreCase));
    }

}
