@model Entities.ViewModels.Students.StudentHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Оценки";
    ViewData["ActiveNav"] = "Grades";
    ViewData["MainClass"] = "nb-academics-main";
    ViewData["ShellUserName"] = Model.StudentName;
    ViewData["ShellUserMeta"] = Model.ClassName;
    ViewData["ShellUserInitials"] = Model.StudentInitials;

    var gradeModalIndex = 0;
    var feedbackModalIndex = 0;
    var absenceModalIndex = 0;
}

@section Styles {
<style>
        .nb-academics-main {
            min-width: 0;
            background: #fbf3ec;
        }
        .nb-academics-content {
            display: grid;
            grid-template-columns: minmax(520px, 1.75fr) minmax(280px, 0.95fr);
            gap: 20px;
            padding: 28px 34px 44px;
        }
        .nb-academics-card {
            border: 1px solid #eee7df;
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
        }
        .nb-academics-card-header {
            min-height: 46px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            padding: 14px 18px 6px;
        }
        .nb-academics-card-header h2 {
            margin: 0;
            color: #1f232b;
            font-size: 13px;
            font-weight: 900;
        }
        .nb-academics-card-header span {
            color: #a49c92;
            font-size: 11px;
            font-weight: 800;
        }
        .nb-grades-panel {
            min-height: 315px;
            padding-bottom: 16px;
        }
        .nb-subject-list {
            display: grid;
            gap: 8px;
            padding: 0 18px 2px;
        }
        .nb-subject-row {
            min-height: 42px;
            display: grid;
            grid-template-columns: 26px minmax(120px, 1fr) auto;
            align-items: center;
            gap: 10px;
        }
        .nb-subject-dot {
            width: 22px;
            height: 22px;
            display: grid;
            place-items: center;
            border-radius: 7px;
            background: #e9ddff;
            color: #7447ff;
        }
        .nb-subject-dot::after {
            content: "";
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: currentColor;
        }
        .nb-subject-row:nth-child(3n + 2) .nb-subject-dot {
            background: #dff0ff;
            color: #3177ff;
        }
        .nb-subject-row:nth-child(3n) .nb-subject-dot {
            background: #dff8e9;
            color: #20a95c;
        }
        .nb-subject-name {
            overflow: hidden;
            color: #3a3f48;
            font-size: 13px;
            font-weight: 800;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .nb-grade-chip-list {
            display: inline-flex;
            justify-content: flex-end;
            gap: 7px;
        }
        .nb-grade-chip,
        .nb-popup-grade {
            min-width: 24px;
            min-height: 22px;
            display: inline-grid;
            place-items: center;
            padding: 2px 7px;
            border: 0;
            border-radius: 999px;
            background: #eee7df;
            color: #8d867c;
            font: inherit;
            font-size: 11px;
            font-weight: 900;
            cursor: pointer;
        }
        .nb-grade-chip:focus-visible,
        .nb-list-button:focus-visible,
        .nb-popup-close:focus-visible,
        a.nb-student-user:focus-visible {
            outline: 2px solid #ffb36d;
            outline-offset: 2px;
        }
        .nb-grade-chip.is-good,
        .nb-popup-grade.is-good,
        .nb-status.is-good {
            background: #dff8e9;
            color: #16a34a;
        }
        .nb-grade-chip.is-mid,
        .nb-popup-grade.is-mid {
            background: #fff0d8;
            color: #e77817;
        }
        .nb-grade-chip.is-low,
        .nb-popup-grade.is-low,
        .nb-status.is-low {
            background: #ffe0dc;
            color: #e04434;
        }
        .nb-grade-placeholder {
            min-width: 24px;
            min-height: 22px;
            display: inline-grid;
            place-items: center;
            padding: 2px 7px;
            border-radius: 999px;
            background: #f0ebe4;
            color: #b7afa5;
            font-size: 11px;
            font-weight: 900;
        }
        .nb-academics-side {
            display: grid;
            align-content: start;
            gap: 18px;
        }
        .nb-side-card {
            min-height: 132px;
            padding-bottom: 16px;
        }
        .nb-side-list {
            display: grid;
            gap: 8px;
            padding: 0 18px;
        }
        .nb-list-button {
            width: 100%;
            min-height: 28px;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 9px;
            padding: 2px 0;
            border: 0;
            background: transparent;
            color: inherit;
            font: inherit;
            text-align: left;
            cursor: pointer;
        }
        .nb-list-pill {
            min-height: 18px;
            display: inline-flex;
            align-items: center;
            padding: 2px 7px;
            border-radius: 999px;
            background: #dff8e9;
            color: #16a34a;
            font-size: 10px;
            font-weight: 900;
            white-space: nowrap;
        }
        .nb-list-button.is-remark .nb-list-pill,
        .nb-list-button.is-unexcused .nb-list-pill {
            background: #ffe0dc;
            color: #e04434;
        }
        .nb-list-lines {
            min-width: 0;
            display: grid;
            gap: 5px;
        }
        .nb-list-line {
            height: 7px;
            border-radius: 999px;
            background: #e8e2da;
        }
        .nb-list-line:first-child {
            width: min(100%, 172px);
        }
        .nb-list-line:last-child {
            width: min(75%, 138px);
        }
        .nb-list-date {
            color: #b1aaa1;
            font-size: 10px;
            font-weight: 850;
            white-space: nowrap;
        }
        .nb-empty-state {
            min-height: 72px;
            display: grid;
            place-items: center;
            margin: 0 18px;
            border-radius: 8px;
            background: #fbf7f2;
            color: #9f978e;
            font-size: 12px;
            font-weight: 850;
            text-align: center;
        }
        .nb-popup-backdrop {
            position: fixed;
            inset: 0;
            z-index: 50;
            display: grid;
            place-items: center;
            padding: 24px;
            background: rgba(31, 35, 43, 0.42);
        }
        .nb-popup-backdrop[hidden] {
            display: none;
        }
        .nb-popup {
            width: min(470px, 100%);
            overflow: hidden;
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 30px 80px rgba(31, 35, 43, 0.28);
        }
        .nb-popup-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 18px 20px;
            border-bottom: 1px solid #eee7df;
        }
        .nb-popup-header h3 {
            margin: 0;
            color: #20232a;
            font-size: 16px;
            font-weight: 900;
        }
        .nb-popup-header p {
            margin: 3px 0 0;
            color: #9a938b;
            font-size: 12px;
            font-weight: 750;
        }
        .nb-popup-close {
            width: 34px;
            height: 34px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            border: 1px solid #f0ded0;
            border-radius: 50%;
            background: #fff8f1;
            color: #e95b0c;
            cursor: pointer;
        }
        .nb-popup-body {
            display: grid;
            gap: 12px;
            padding: 18px 20px 20px;
        }
        .nb-popup-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 7px;
        }
        .nb-popup-meta span,
        .nb-status {
            min-height: 23px;
            display: inline-flex;
            align-items: center;
            padding: 3px 9px;
            border-radius: 999px;
            background: #f0ebe4;
            color: #81786f;
            font-size: 11px;
            font-weight: 850;
        }
        .nb-popup-comment {
            margin: 0;
            padding: 12px;
            border-radius: 8px;
            background: #fbf7f2;
            color: #514b45;
            font-size: 13px;
            line-height: 1.45;
        }
        body.nb-popup-open {
            overflow: hidden;
        }
        a.nb-student-user {
            color: inherit;
            text-decoration: none;
            transition: background 0.16s ease, box-shadow 0.16s ease;
        }
        a.nb-student-user:hover,
        a.nb-student-user:focus-visible {
            background: #ffeede;
            box-shadow: 0 10px 20px rgba(42, 35, 29, 0.06);
        }
        @@media (max-width: 1040px) {
            .nb-academics-content {
                grid-template-columns: 1fr;
            }
        }
        @@media (max-width: 640px) {
            .nb-academics-content {
                padding: 18px 16px 32px;
            }
            .nb-subject-row {
                grid-template-columns: 26px minmax(0, 1fr);
                align-items: start;
            }
            .nb-grade-chip-list {
                grid-column: 2;
                justify-content: flex-start;
                flex-wrap: wrap;
            }
            .nb-list-button {
                grid-template-columns: 1fr auto;
            }
            .nb-list-pill {
                grid-column: 1;
                width: fit-content;
            }
            .nb-popup-backdrop {
                padding: 12px;
            }
        }
    </style>
}

<section class="nb-academics-content">
<article class="nb-academics-card nb-grades-panel">
    <div class="nb-academics-card-header">
        <h2>Оценки</h2>
        <span>Средно @Model.OverallAverage.ToString("0.00")</span>
    </div>

    @if (Model.AcademicSubjects.Any())
    {
        <div class="nb-subject-list">
            @foreach (var subject in Model.AcademicSubjects)
            {
                <div class="nb-subject-row">
                    <span class="nb-subject-dot" aria-hidden="true"></span>
                    <span class="nb-subject-name" title="@subject.SubjectName">@subject.SubjectName</span>
                    <span class="nb-grade-chip-list" aria-label="Оценки по @subject.SubjectName">
                        @if (subject.Grades.Any())
                        {
                            @foreach (var grade in subject.Grades)
                            {
                                gradeModalIndex++;
                                var modalId = $"grade-popup-{gradeModalIndex}";
                                var gradeTone = grade.Value >= 5 ? "is-good" : grade.Value >= 4 ? "is-mid" : "is-low";
                                var gradeValue = grade.Value.ToString("0.##");

                                <button class="nb-grade-chip @gradeTone" type="button" data-nb-popup-open="@modalId" aria-label="Отвори детайли за оценка @gradeValue по @subject.SubjectName">
                                    @gradeValue
                                </button>
                            }
                        }
                        else
                        {
                            <span class="nb-grade-placeholder">0</span>
                        }
                    </span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="nb-empty-state">Все още няма добавени предмети.</div>
    }
</article>

<div class="nb-academics-side">
    <article class="nb-academics-card nb-side-card">
        <div class="nb-academics-card-header">
            <h2>Отзиви</h2>
            <span>@Model.FeedbackSummary.Count</span>
        </div>

        @if (Model.Feedbacks.Any())
        {
            <div class="nb-side-list">
                @foreach (var feedback in Model.Feedbacks.Take(4))
                {
                    feedbackModalIndex++;
                    var modalId = $"feedback-popup-{feedbackModalIndex}";
                    var feedbackClass = feedback.Type == "Похвала" ? "is-praise" : "is-remark";

                    <button class="nb-list-button @feedbackClass" type="button" data-nb-popup-open="@modalId">
                        <span class="nb-list-pill">@feedback.Type</span>
                        <span class="nb-list-lines" aria-hidden="true">
                            <span class="nb-list-line"></span>
                            <span class="nb-list-line"></span>
                        </span>
                        <span class="nb-list-date">@feedback.Date.ToString("dd.MM")</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="nb-empty-state">Все още няма отзиви.</div>
        }
    </article>

    <article class="nb-academics-card nb-side-card">
        <div class="nb-academics-card-header">
            <h2>Отсъствия</h2>
            <span>@Model.AbsenceSummary.Count</span>
        </div>

        @if (Model.Absences.Any())
        {
            <div class="nb-side-list">
                @foreach (var absence in Model.Absences.Take(4))
                {
                    absenceModalIndex++;
                    var modalId = $"absence-popup-{absenceModalIndex}";
                    var absenceClass = absence.Status == "Уважено" ? "is-excused" : "is-unexcused";

                    <button class="nb-list-button @absenceClass" type="button" data-nb-popup-open="@modalId">
                        <span class="nb-list-lines" aria-hidden="true">
                            <span class="nb-list-line"></span>
                            <span class="nb-list-line"></span>
                        </span>
                        <span class="nb-list-date">@absence.Date.ToString("dd.MM")</span>
                        <span class="nb-list-pill">@absence.Status</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="nb-empty-state">Все още няма отсъствия.</div>
        }
    </article>
</div>
</section>

@{
gradeModalIndex = 0;
feedbackModalIndex = 0;
absenceModalIndex = 0;
}

@foreach (var subject in Model.AcademicSubjects)
{
foreach (var grade in subject.Grades)
{
gradeModalIndex++;
var modalId = $"grade-popup-{gradeModalIndex}";
var gradeTone = grade.Value >= 5 ? "is-good" : grade.Value >= 4 ? "is-mid" : "is-low";

<div class="nb-popup-backdrop" data-nb-popup="@modalId" hidden>
<section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{modalId}-title")" tabindex="-1">
    <header class="nb-popup-header">
        <div>
            <h3 id="@($"{modalId}-title")">@grade.SubjectName</h3>
            <p>@grade.Type</p>
        </div>
        <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
            <i class="bi bi-x-lg"></i>
        </button>
    </header>
    <div class="nb-popup-body">
        <span class="nb-popup-grade @gradeTone">@grade.Value.ToString("0.##")</span>
        <div class="nb-popup-meta">
            <span>@grade.TeacherName</span>
            <span>@grade.Date.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
        <p class="nb-popup-comment">@grade.Comment</p>
    </div>
</section>
</div>
}
}

@foreach (var feedback in Model.Feedbacks.Take(4))
{
feedbackModalIndex++;
var modalId = $"feedback-popup-{feedbackModalIndex}";
var feedbackTone = feedback.Type == "Похвала" ? "is-good" : "is-low";

<div class="nb-popup-backdrop" data-nb-popup="@modalId" hidden>
<section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{modalId}-title")" tabindex="-1">
<header class="nb-popup-header">
    <div>
        <h3 id="@($"{modalId}-title")">@feedback.SubjectName</h3>
        <p>@feedback.Type</p>
    </div>
    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
        <i class="bi bi-x-lg"></i>
    </button>
</header>
<div class="nb-popup-body">
    <div class="nb-popup-meta">
        <span class="nb-status @feedbackTone">@feedback.Type</span>
        <span>@feedback.TeacherName</span>
        <span>@feedback.Date.ToString("dd.MM.yyyy")</span>
    </div>
    <p class="nb-popup-comment">@feedback.Comment</p>
</div>
</section>
</div>
}

@foreach (var absence in Model.Absences.Take(4))
{
absenceModalIndex++;
var modalId = $"absence-popup-{absenceModalIndex}";
var absenceTone = absence.Status == "Уважено" ? "is-good" : "is-low";

<div class="nb-popup-backdrop" data-nb-popup="@modalId" hidden>
<section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{modalId}-title")" tabindex="-1">
<header class="nb-popup-header">
    <div>
        <h3 id="@($"{modalId}-title")">@absence.SubjectName</h3>
        <p>@absence.Type</p>
    </div>
    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
        <i class="bi bi-x-lg"></i>
    </button>
</header>
<div class="nb-popup-body">
    <div class="nb-popup-meta">
        <span class="nb-status @absenceTone">@absence.Status</span>
        <span>@absence.TeacherName</span>
        <span>@absence.Date.ToString("dd.MM.yyyy")</span>
        <span>Час @absence.LessonNumber</span>
        <span>@absence.ExcuseReason</span>
    </div>
    <p class="nb-popup-comment">@absence.Comment</p>
</div>
</section>
</div>
}

@section Scripts {
<script>
(() => {
const triggers = document.querySelectorAll("[data-nb-popup-open]");
const popups = document.querySelectorAll("[data-nb-popup]");
let activeTrigger = null;

const closePopup = (popup) => {
if (!popup) {
    return;
}

popup.hidden = true;
document.body.classList.remove("nb-popup-open");

if (activeTrigger) {
    activeTrigger.focus();
    activeTrigger = null;
}
};

const openPopup = (id, trigger) => {
const popup = document.querySelector(`[data-nb-popup="${id}"]`);
if (!popup) {
    return;
}

activeTrigger = trigger;
popup.hidden = false;
document.body.classList.add("nb-popup-open");
popup.querySelector(".nb-popup")?.focus();
};

triggers.forEach((trigger) => {
trigger.addEventListener("click", () => {
    openPopup(trigger.dataset.nbPopupOpen, trigger);
});
});

popups.forEach((popup) => {
popup.addEventListener("click", (event) => {
    if (event.target === popup || event.target.closest("[data-nb-popup-close]")) {
        closePopup(popup);
    }
});
});

document.addEventListener("keydown", (event) => {
if (event.key === "Escape") {
    closePopup(document.querySelector("[data-nb-popup]:not([hidden])"));
}
});
})();
</script>
}
