@model Web.ViewModels.NewsIndexViewModel

@{
    var isPrincipal = User.IsInRole("Principal");

    Layout = isPrincipal ? null : "_Layout";
    ViewData["Title"] = "Новини";
}

@if (isPrincipal)
{
    <!DOCTYPE html>
    <html lang="bg">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Новини - NemeBook</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </head>
    <body class="nb-principal-body">
        <div class="nb-principal-shell">
            <partial name="~/Views/Admin/Shared/_PrincipalSideNav.cshtml" model='@("News")' />

            <main class="nb-principal-main">
                <header class="nb-principal-topbar">
                    <h1>Новини</h1>
                    <partial name="_PrincipalStudentSearch" />
                    <div class="nb-principal-top-actions">
                        <form asp-action="Logout" asp-area="" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            <button class="nb-principal-action-btn is-logout" type="submit">
                                <span>Изход</span>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            </button>
                        </form>
                    </div>
                </header>

                <section class="nb-principal-content nb-news-admin-content" aria-label="Новини">
                    <partial name="_NewsFeed" model="Model" />
                </section>
            </main>
        </div>
    </body>
    </html>
}
else
{
    <section class="nb-news-page" aria-label="Новини">
        <partial name="_NewsFeed" model="Model" />
    </section>
}
