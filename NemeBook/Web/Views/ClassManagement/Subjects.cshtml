@using System.ComponentModel.DataAnnotations
@using Entities.Enums
@model Web.ViewModels.PrincipalClassManagementViewModel

@{
    Layout = null;
    ViewData["Title"] = $"Клас {Model.ClassName} - Предмети";

    var principalDisplayName = typeof(UserRole)
        .GetMember(nameof(UserRole.Principal))[0]
        .GetCustomAttributes(typeof(DisplayAttribute), false)
        .Cast<DisplayAttribute>()
        .FirstOrDefault()
        ?.GetName() ?? nameof(UserRole.Principal);
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Клас @Model.ClassName - Предмети - NemeBook</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="nb-principal-body">
    <div class="nb-principal-shell">
        <aside class="nb-principal-sidebar" aria-label="Главна навигация">
            <a class="nb-principal-logo" asp-controller="Home" asp-action="Index">
                <span class="nb-principal-logo-mark">
                    <i class="bi bi-book-half" aria-hidden="true"></i>
                </span>
                <span>
                    <strong>NemeBook</strong>
                    <small>@principalDisplayName</small>
                </span>
            </a>

            <nav class="nb-principal-nav">
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-fill" aria-hidden="true"></i>
                    <span>Начало</span>
                </a>
                <a href="#">
                    <i class="bi bi-newspaper" aria-hidden="true"></i>
                    <span>Новини</span>
                </a>
                <a class="is-active" asp-controller="Grade" asp-action="AllClasses">
                    <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                    <span>Класове</span>
                </a>
                <a asp-controller="Chat" asp-action="Index">
                    <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
                    <span>Учителски чатове</span>
                </a>
                <a asp-controller="ProfileImport" asp-action="Index">
                    <i class="bi bi-upload" aria-hidden="true"></i>
                    <span>Импорт на профили</span>
                </a>
            </nav>

            <a class="nb-principal-user-card" asp-controller="Account" asp-action="Profile">
                <span class="nb-principal-user-avatar"></span>
                <span>
                    <strong>@(User.FindFirst("FullName")?.Value ?? "Директор")</strong>
                    <small>Директорски профил</small>
                </span>
            </a>
        </aside>

        <main class="nb-principal-main">
            <header class="nb-principal-topbar">
                <h1>Клас @Model.ClassName</h1>
                <partial name="_PrincipalStudentSearch" />
                <div class="nb-principal-top-actions">
                    <form asp-action="Logout" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button class="nb-principal-action-btn is-logout" type="submit">
                            <span>Изход</span>
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </header>

            <section class="nb-principal-content nb-class-management-content" aria-label="Управление на клас">
                <div class="nb-class-management-tabs-row">
                    <nav class="nb-class-management-tabs" aria-label="Секции на класа">
                        <a class="@GetTabClass("Class")" asp-controller="ClassManagement" asp-action="Students" asp-route-classId="@Model.ClassId">Клас</a>
                        <a class="@GetTabClass("Subjects")" asp-controller="ClassManagement" asp-action="Subjects" asp-route-classId="@Model.ClassId">Предмети</a>
                        <a class="@GetTabClass("Schedule")" asp-controller="ClassManagement" asp-action="Schedule" asp-route-classId="@Model.ClassId">Програма</a>
                        <a class="@GetTabClass("Events")" asp-controller="ClassManagement" asp-action="Events" asp-route-classId="@Model.ClassId">Събития</a>
                    </nav>
                    <a class="nb-principal-action-btn nb-class-back-btn" asp-controller="Grade" asp-action="AllClasses" asp-route-grade="@GetGradeNumber(Model.ClassName)">
                        <span>Всички класове</span>
                        <i class="bi bi-arrow-left" aria-hidden="true"></i>
                    </a>
                </div>

                <section class="nb-class-students-panel nb-class-subjects-panel" aria-labelledby="class-subjects-title">
                    <div class="nb-class-section-header">
                        <h2 id="class-subjects-title">Предмети</h2>
                        <button class="nb-class-add-subject-btn" type="button" id="openSubjectDialog">
                            <i class="bi bi-plus-lg" aria-hidden="true"></i>
                            <span>Добави предмет</span>
                        </button>
                    </div>

                    @if (Model.ClassSubjects.Count == 0)
                    {
                        <div class="nb-class-subjects-empty">
                            <span>В този клас все още няма добавени предмети.</span>
                        </div>
                    }
                    else
                    {
                        <div class="nb-class-subjects-list">
                            @foreach (var classSubject in Model.ClassSubjects)
                            {
                                <article class="nb-class-subject-row"
                                         data-class-subject-id="@classSubject.ClassSubjectId"
                                         data-subject-id="@classSubject.SubjectId"
                                         data-subject-name="@classSubject.SubjectName"
                                         data-teacher-id="@classSubject.TeacherId"
                                         data-teacher-name="@classSubject.TeacherName">
                                    <div class="nb-class-subject-info">
                                        <strong>@classSubject.SubjectName</strong>
                                        <span>@(classSubject.TeacherName ?? "Няма избран учител")</span>
                                    </div>
                                    <div class="nb-class-subject-actions">
                                        <button class="nb-class-subject-action-btn js-edit-class-subject"
                                                type="button"
                                                aria-label="Редактирай учител за @classSubject.SubjectName">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        </button>
                                        <form asp-controller="ClassManagement"
                                              asp-action="DeleteClassSubject"
                                              method="post"
                                              onsubmit="return confirm('Сигурни ли сте, че искате да премахнете този предмет от класа?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="classId" value="@Model.ClassId" />
                                            <input type="hidden" name="classSubjectId" value="@classSubject.ClassSubjectId" />
                                            <button class="nb-class-subject-action-btn is-danger"
                                                    type="submit"
                                                    aria-label="Премахни @classSubject.SubjectName от класа">
                                                <i class="bi bi-trash3" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </section>
        </main>
    </div>

    <div class="nb-modal-backdrop" id="subjectDialog" aria-hidden="true">
        <section class="nb-subject-dialog" role="dialog" aria-modal="true" aria-labelledby="subject-dialog-title">
            <div class="nb-subject-dialog-header">
                <h2 id="subject-dialog-title">Добави предмет</h2>
                <button class="nb-dialog-close" type="button" id="closeSubjectDialog" aria-label="Затвори">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
            </div>

            <form asp-controller="ClassManagement" asp-action="AddClassSubject" method="post" id="addClassSubjectForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classId" value="@Model.ClassId" />
                <input type="hidden" name="classSubjectId" id="selectedClassSubjectId" />
                <input type="hidden" name="subjectId" id="selectedSubjectId" />
                <input type="hidden" name="teacherId" id="selectedSubjectTeacherId" />

                <div class="nb-subject-form-field" id="subjectSelectField">
                    <label for="subjectSelect">Предмет</label>
                    <select id="subjectSelect">
                        <option value="" selected hidden></option>
                        <option value="new">+ Нов предмет</option>
                        @foreach (var subject in Model.SubjectOptions)
                        {
                            <option value="@subject.Id">@subject.Name</option>
                        }
                    </select>
                </div>

                <div class="nb-subject-form-field" id="selectedSubjectDisplayField" hidden>
                    <span class="nb-subject-locked-label">Предмет</span>
                    <strong class="nb-subject-locked-value" id="selectedSubjectDisplay"></strong>
                </div>

                <div class="nb-new-subject-row" id="newSubjectRow" hidden>
                    <div class="nb-new-subject-search">
                        <input type="text" id="newSubjectName" placeholder="Име на предмет" autocomplete="off" />
                        <div class="nb-new-subject-dropdown" id="newSubjectMatches" role="listbox" hidden></div>
                    </div>
                    <button type="button" id="createSubjectButton">Добави нов предмет</button>
                </div>

                <div class="nb-subject-form-field" id="teacherPickerSection" hidden>
                    <label for="subjectTeacherSearch">Учител</label>
                    <div class="nb-subject-teacher-row">
                        <div class="nb-subject-teacher-search">
                            <i class="bi bi-search" aria-hidden="true"></i>
                            <input id="subjectTeacherSearch"
                                   type="search"
                                   placeholder="Търси учител"
                                   autocomplete="off" />
                            <div class="nb-subject-teacher-dropdown" role="listbox" hidden></div>
                        </div>
                        <button type="button" class="nb-show-all-teachers-btn" id="toggleAllTeachers">
                            Покажи всички учители
                        </button>
                    </div>
                </div>

                <button class="nb-add-class-subject-submit" id="addClassSubjectButton" type="submit" hidden>
                    Добави предмет
                </button>
            </form>
        </section>
    </div>

    <script>
        (function () {
            const dialog = document.getElementById('subjectDialog');
            const openDialog = document.getElementById('openSubjectDialog');
            const closeDialog = document.getElementById('closeSubjectDialog');
            const form = document.getElementById('addClassSubjectForm');
            const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
            const dialogTitle = document.getElementById('subject-dialog-title');
            const subjectSelectField = document.getElementById('subjectSelectField');
            const selectedSubjectDisplayField = document.getElementById('selectedSubjectDisplayField');
            const selectedSubjectDisplay = document.getElementById('selectedSubjectDisplay');
            const subjectSelect = document.getElementById('subjectSelect');
            const selectedClassSubjectId = document.getElementById('selectedClassSubjectId');
            const selectedSubjectId = document.getElementById('selectedSubjectId');
            const selectedTeacherId = document.getElementById('selectedSubjectTeacherId');
            const newSubjectRow = document.getElementById('newSubjectRow');
            const newSubjectName = document.getElementById('newSubjectName');
            const newSubjectMatches = document.getElementById('newSubjectMatches');
            const createSubjectButton = document.getElementById('createSubjectButton');
            const teacherPickerSection = document.getElementById('teacherPickerSection');
            const teacherSearch = document.getElementById('subjectTeacherSearch');
            const teacherDropdown = document.querySelector('.nb-subject-teacher-dropdown');
            const toggleAllTeachers = document.getElementById('toggleAllTeachers');
            const submitButton = document.getElementById('addClassSubjectButton');
            const addClassSubjectUrl = '@Url.Action("AddClassSubject", "ClassManagement")';
            const updateClassSubjectTeacherUrl = '@Url.Action("UpdateClassSubjectTeacher", "ClassManagement")';
            const createSubjectUrl = '@Url.Action("CreateSubject", "ClassManagement")';
            const teacherSearchUrl = '@Url.Action("SearchClassSubjectTeacherMatches", "ClassManagement")';
            const subjectOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.SubjectOptions.Select(subject => new { id = subject.Id, name = subject.Name })));
            let includeAllTeachers = false;
            let abortController = null;

            function resetTeacher() {
                selectedTeacherId.value = '';
                teacherSearch.value = '';
                submitButton.hidden = true;
                teacherDropdown.hidden = true;
                teacherDropdown.innerHTML = '';
            }

            function resetForm() {
                form.action = addClassSubjectUrl;
                dialogTitle.textContent = 'Добави предмет';
                submitButton.textContent = 'Добави предмет';
                subjectSelectField.hidden = false;
                selectedSubjectDisplayField.hidden = true;
                selectedSubjectDisplay.textContent = '';
                subjectSelect.value = '';
                selectedClassSubjectId.value = '';
                selectedSubjectId.value = '';
                newSubjectRow.hidden = true;
                newSubjectName.value = '';
                closeNewSubjectMatches();
                teacherPickerSection.hidden = true;
                includeAllTeachers = false;
                toggleAllTeachers.textContent = 'Покажи всички учители';
                resetTeacher();
            }

            function showAddDialog() {
                resetForm();
                dialog.classList.add('is-visible');
                dialog.setAttribute('aria-hidden', 'false');
                subjectSelect.focus();
            }

            function showEditDialog(classSubjectRow) {
                resetForm();
                form.action = updateClassSubjectTeacherUrl;
                dialogTitle.textContent = 'Редактирай учител';
                submitButton.textContent = 'Запази учител';
                subjectSelectField.hidden = true;
                selectedSubjectDisplayField.hidden = false;
                selectedClassSubjectId.value = classSubjectRow.dataset.classSubjectId || '';
                selectedSubjectId.value = classSubjectRow.dataset.subjectId || '';
                selectedTeacherId.value = classSubjectRow.dataset.teacherId || '';
                selectedSubjectDisplay.textContent = classSubjectRow.dataset.subjectName || '';
                teacherSearch.value = classSubjectRow.dataset.teacherName || '';
                teacherPickerSection.hidden = false;
                submitButton.hidden = !selectedTeacherId.value;
                dialog.classList.add('is-visible');
                dialog.setAttribute('aria-hidden', 'false');
                teacherSearch.focus();
            }

            function hideDialog() {
                dialog.classList.remove('is-visible');
                dialog.setAttribute('aria-hidden', 'true');
            }

            function showTeacherPicker() {
                teacherPickerSection.hidden = false;
                resetTeacher();
            }

            function closeNewSubjectMatches() {
                newSubjectMatches.hidden = true;
                newSubjectMatches.innerHTML = '';
            }

            function selectExistingSubject(subject) {
                let option = Array.from(subjectSelect.options)
                    .find(function (currentOption) {
                        return currentOption.value === subject.id;
                    });

                if (!option) {
                    option = document.createElement('option');
                    option.value = subject.id;
                    option.textContent = subject.name;
                    subjectSelect.appendChild(option);
                }

                subjectSelect.value = subject.id;
                selectedSubjectId.value = subject.id;
                newSubjectRow.hidden = true;
                newSubjectName.value = '';
                closeNewSubjectMatches();
                showTeacherPicker();
            }

            function renderNewSubjectMatches() {
                const query = newSubjectName.value.trim().toLocaleLowerCase('bg-BG');
                closeNewSubjectMatches();

                if (query.length < 2) {
                    return;
                }

                const matches = subjectOptions
                    .filter(function (subject) {
                        return subject.name.toLocaleLowerCase('bg-BG').includes(query);
                    })
                    .sort(function (first, second) {
                        return first.name.localeCompare(second.name, 'bg');
                    })
                    .slice(0, 8);

                if (matches.length === 0) {
                    return;
                }

                matches.forEach(function (subject) {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.setAttribute('role', 'option');
                    button.textContent = subject.name;
                    button.addEventListener('click', function () {
                        selectExistingSubject(subject);
                    });
                    newSubjectMatches.appendChild(button);
                });

                newSubjectMatches.hidden = false;
            }

            function renderTeacherResults(results) {
                teacherDropdown.innerHTML = '';

                if (results.length === 0) {
                    const empty = document.createElement('span');
                    empty.className = 'nb-subject-teacher-empty';
                    empty.textContent = 'Няма намерени учители';
                    teacherDropdown.appendChild(empty);
                    teacherDropdown.hidden = false;
                    return;
                }

                results.forEach(function (teacher) {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.setAttribute('role', 'option');
                    button.textContent = teacher.fullName;

                    button.addEventListener('click', function () {
                        teacherSearch.value = teacher.fullName;
                        selectedTeacherId.value = teacher.id;
                        submitButton.hidden = false;
                        teacherDropdown.hidden = true;
                        teacherDropdown.innerHTML = '';
                    });

                    teacherDropdown.appendChild(button);
                });

                teacherDropdown.hidden = false;
            }

            function searchTeachers(clearSelectedTeacher) {
                const query = teacherSearch.value.trim();

                if (clearSelectedTeacher !== false) {
                    selectedTeacherId.value = '';
                    submitButton.hidden = true;
                }

                if (abortController) {
                    abortController.abort();
                }

                if (!selectedSubjectId.value) {
                    teacherDropdown.hidden = true;
                    teacherDropdown.innerHTML = '';
                    return;
                }

                abortController = new AbortController();

                fetch(
                    teacherSearchUrl
                    + '?subjectId=' + encodeURIComponent(selectedSubjectId.value)
                    + '&query=' + encodeURIComponent(query)
                    + '&includeAllTeachers=' + includeAllTeachers,
                    {
                        headers: { 'Accept': 'application/json' },
                        signal: abortController.signal
                    })
                    .then(function (response) {
                        return response.ok ? response.json() : [];
                    })
                    .then(renderTeacherResults)
                    .catch(function (error) {
                        if (error.name !== 'AbortError') {
                            teacherDropdown.hidden = true;
                        }
                    });
            }

            openDialog.addEventListener('click', showAddDialog);
            closeDialog.addEventListener('click', hideDialog);

            document.querySelectorAll('.js-edit-class-subject').forEach(function (button) {
                button.addEventListener('click', function () {
                    showEditDialog(button.closest('.nb-class-subject-row'));
                });
            });

            dialog.addEventListener('click', function (event) {
                if (event.target === dialog) {
                    hideDialog();
                }
            });

            subjectSelect.addEventListener('change', function () {
                resetTeacher();

                if (subjectSelect.value === 'new') {
                    selectedSubjectId.value = '';
                    teacherPickerSection.hidden = true;
                    newSubjectRow.hidden = false;
                    newSubjectName.value = '';
                    closeNewSubjectMatches();
                    newSubjectName.focus();
                    return;
                }

                newSubjectRow.hidden = true;
                closeNewSubjectMatches();
                selectedSubjectId.value = subjectSelect.value;

                if (selectedSubjectId.value) {
                    showTeacherPicker();
                }
                else {
                    teacherPickerSection.hidden = true;
                }
            });

            createSubjectButton.addEventListener('click', function () {
                const name = newSubjectName.value.trim();

                if (!name) {
                    newSubjectName.focus();
                    return;
                }

                const formData = new FormData();
                formData.append('__RequestVerificationToken', token);
                formData.append('name', name);
                createSubjectButton.disabled = true;

                fetch(createSubjectUrl, {
                    method: 'POST',
                    body: formData,
                    headers: { 'Accept': 'application/json' }
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Subject creation failed.');
                        }

                        return response.json();
                    })
                    .then(function (subject) {
                        let option = Array.from(subjectSelect.options)
                            .find(function (currentOption) {
                                return currentOption.value === subject.id;
                            });

                        if (!option) {
                            option = document.createElement('option');
                            option.value = subject.id;
                            option.textContent = subject.name;
                            subjectSelect.appendChild(option);
                        }

                        if (!subjectOptions.some(function (currentSubject) { return currentSubject.id === subject.id; })) {
                            subjectOptions.push({ id: subject.id, name: subject.name });
                        }

                        subjectSelect.value = subject.id;
                        selectedSubjectId.value = subject.id;
                        newSubjectRow.hidden = true;
                        newSubjectName.value = '';
                        closeNewSubjectMatches();
                        showTeacherPicker();
                    })
                    .finally(function () {
                        createSubjectButton.disabled = false;
                    });
            });

            newSubjectName.addEventListener('input', renderNewSubjectMatches);
            newSubjectName.addEventListener('focus', renderNewSubjectMatches);

            teacherSearch.addEventListener('input', function () {
                searchTeachers(true);
            });
            teacherSearch.addEventListener('focus', function () {
                searchTeachers(false);
            });

            toggleAllTeachers.addEventListener('click', function () {
                includeAllTeachers = !includeAllTeachers;
                toggleAllTeachers.textContent = includeAllTeachers
                    ? 'Покажи само по предмет'
                    : 'Покажи всички учители';
                searchTeachers(false);
            });

            document.addEventListener('click', function (event) {
                if (!teacherPickerSection.contains(event.target)) {
                    teacherDropdown.hidden = true;
                }

                if (!newSubjectRow.contains(event.target)) {
                    closeNewSubjectMatches();
                }
            });

            form.addEventListener('submit', function (event) {
                if (!selectedSubjectId.value || !selectedTeacherId.value) {
                    event.preventDefault();
                }
            });
        }());
    </script>
</body>
</html>

@functions {
    private string GetTabClass(string tab)
    {
        return Model.ActiveTab == tab ? "is-active" : string.Empty;
    }

    private static int GetGradeNumber(string className)
    {
        var digits = new string(className.TakeWhile(char.IsDigit).ToArray());
        return int.TryParse(digits, out var gradeNumber) ? gradeNumber : 1;
    }
}
