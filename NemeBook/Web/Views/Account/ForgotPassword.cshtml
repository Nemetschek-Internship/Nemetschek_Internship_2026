@model Entities.ViewModels.Auth.ForgotPasswordRequest

@{
    ViewData["Title"] = "Забравена парола";
}

<div class="nb-form-shell">
    <section class="nb-form-card nb-login-card" aria-labelledby="forgot-password-title">
        <div class="nb-auth-brand">
            <div class="nb-auth-logo">N</div>
            <div class="nb-auth-name"><span>Neme</span>Book</div>
        </div>

        <h1 id="forgot-password-title">Забравена парола</h1>
        <p class="nb-form-subtitle">Въведете имейла си и ще ви изпратим линк за смяна на паролата.</p>

        <form asp-action="ForgotPassword" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>

            <div class="nb-form-field">
                <label asp-for="Email" class="nb-form-label">Имейл</label>
                <div class="nb-input-shell">
                    <i class="bi bi-envelope-fill" aria-hidden="true"></i>
                    <input asp-for="Email" class="nb-form-input" placeholder="you@school.bg" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="nb-validation"></span>
            </div>

            <button type="submit" class="nb-primary-action">Изпрати линк</button>

            <p class="nb-form-note">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                Линкът е валиден 30 минути.
            </p>
        </form>

        <div class="nb-login-help">
            <p><a class="nb-text-link" asp-action="Login">Обратно към вход</a></p>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
