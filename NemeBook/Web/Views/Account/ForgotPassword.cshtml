@model Entities.ViewModels.Auth.ForgotPasswordRequest

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow border-0">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="bi bi-envelope"></i> Forgot Password</h4>
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Enter your account email and we will send you a secure link to reset your password.
                </p>

                <form asp-action="ForgotPassword" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@school.bg" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-send"></i> Send reset link
                        </button>
                        <a asp-action="Login" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to login
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
