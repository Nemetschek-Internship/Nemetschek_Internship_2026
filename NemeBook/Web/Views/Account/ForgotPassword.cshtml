@model Entities.ViewModels.Auth.ForgotPasswordRequest

@{
    ViewData["Title"] = "Забравена парола";
}

<div class="nb-login-page">
    <aside class="nb-login-brand-panel" aria-hidden="true">
        <div class="nb-login-brand-content">
            <div class="nb-login-brand-orb"></div>
            <div class="nb-login-wordmark"><span>Neme</span>Book</div>
            <p>Оценки, домашни и съобщения - за ученици, учители и родители.</p>
        </div>
    </aside>

    <main class="nb-login-card-area">
    <section class="nb-login-panel" aria-labelledby="forgot-password-title">
        <h1 id="forgot-password-title">Забравена парола</h1>
        <p class="nb-login-subtitle">Въведете имейла си и ще ви изпратим линк за смяна на паролата.</p>

        <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm" novalidate>
            <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>

            <div class="nb-form-field">
                <label asp-for="Email" class="nb-form-label">Имейл</label>
                <input asp-for="Email" class="nb-login-input" placeholder="ime@uchilishte.bg" autocomplete="email" />
                <span asp-validation-for="Email" class="nb-validation"></span>
            </div>

            <button type="submit" class="nb-primary-action" id="forgotPasswordSubmit">Изпрати линк</button>

            <p class="nb-form-note">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                Линкът е валиден 30 минути.
            </p>
        </form>

        <div class="nb-login-help">
            <p><a class="nb-text-link" asp-action="Login">Обратно към вход</a></p>
        </div>
    </section>
    </main>
</div>

<div class="nb-loading-overlay" id="forgotPasswordLoading" role="status" aria-live="polite" aria-hidden="true">
    <div class="nb-loading-panel">
        <span class="nb-loading-spinner" aria-hidden="true"></span>
        <strong>Изпращаме линк</strong>
        <span>Моля, изчакайте. Проверяваме имейла и изпращаме линк за смяна на паролата.</span>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const forgotPasswordForm = document.getElementById('forgotPasswordForm');
        const forgotPasswordSubmit = document.getElementById('forgotPasswordSubmit');
        const forgotPasswordLoading = document.getElementById('forgotPasswordLoading');

        forgotPasswordForm.addEventListener('submit', function () {
            if (window.jQuery && !$(forgotPasswordForm).valid()) {
                return;
            }

            forgotPasswordLoading.classList.add('is-visible');
            forgotPasswordLoading.setAttribute('aria-hidden', 'false');
            forgotPasswordSubmit.disabled = true;
            forgotPasswordSubmit.innerHTML = '<span class="nb-button-spinner" aria-hidden="true"></span> Изпраща се...';
        });
    </script>
}
