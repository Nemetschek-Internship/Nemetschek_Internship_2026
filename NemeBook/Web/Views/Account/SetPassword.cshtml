@model Entities.ViewModels.Auth.SetPasswordViewModel

@{
    Layout = null;
    ViewData["Title"] = "Set Password";
    var formAction = ViewData["FormAction"]?.ToString() ?? "SetPassword";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NemeBook — Create a new password</title>
    <style>
        :root {
            --orange: #F97316;
            --orange-dark: #EA580C;
            --ink: #1F2937;
            --muted: #6B7280;
            --border: #E5E7EB;
            --bg: #F9FAFB;
            --strong-green: #16A34A;
            --strength-weak: #EF4444;
            --strength-medium: #F59E0B;
            --strength-strong: #16A34A;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            color: var(--ink);
            padding: 20px;
        }

        .card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 16px;
            padding: 40px 32px;
            box-shadow: 0 8px 30px rgba(17,24,39,0.08);
        }

        .logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            margin-bottom: 28px;
        }

        .logo-mark {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #F97316, #EA580C);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25);
        }

        .logo-text {
            font-size: 22px;
            font-weight: 700;
            color: var(--ink);
            letter-spacing: -0.5px;
        }

        .logo-text span {
            color: var(--orange);
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin: 0 0 8px;
            color: var(--ink);
        }

        .subtitle {
            text-align: center;
            color: var(--muted);
            font-size: 14px;
            margin: 0 0 28px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 8px;
        }

        .field {
            margin-bottom: 20px;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 12px 14px;
            background: #fff;
            transition: all 0.2s ease;
        }

        .input-wrap:focus-within {
            border-color: var(--orange);
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
        }

        .input-wrap svg.lock {
            width: 16px;
            height: 16px;
            color: var(--orange);
            margin-right: 10px;
            flex-shrink: 0;
        }

        .input-wrap input {
            border: none;
            outline: none;
            flex: 1;
            font-size: 15px;
            letter-spacing: 1px;
            color: var(--ink);
            background: transparent;
            width: 100%;
            font-weight: 500;
        }

        .input-wrap input::placeholder {
            color: var(--muted);
        }

        .toggle-eye {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4px;
            margin-left: 8px;
            transition: color 0.2s ease;
            border-radius: 4px;
        }

        .toggle-eye:hover {
            color: var(--orange);
            background: rgba(249, 115, 22, 0.05);
        }

        .toggle-eye svg {
            width: 18px;
            height: 18px;
        }

        .strength-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

        .strength-bar {
            flex: 1;
            height: 6px;
            border-radius: 3px;
            background: var(--border);
            overflow: hidden;
        }

        .strength-bar span {
            display: block;
            height: 100%;
            width: 0%;
            background: var(--border);
            border-radius: 3px;
            transition: width 0.3s ease, background-color 0.3s ease;
        }

        .strength-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            white-space: nowrap;
            min-width: 70px;
            text-align: right;
        }

        .submit-btn {
            width: 100%;
            padding: 14px;
            margin-top: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--orange), var(--orange-dark));
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(234,88,12,0.3);
            transition: all 0.2s ease;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(234,88,12,0.4);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        .hint {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            margin-top: 24px;
            padding: 14px;
            background: #FFF7ED;
            border-radius: 10px;
            border-left: 4px solid var(--orange);
            font-size: 13px;
            color: #92400E;
            line-height: 1.5;
        }

        .hint svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
            margin-top: 2px;
            color: var(--orange);
        }

        .footer {
            text-align: center;
            margin-top: 24px;
            font-size: 13px;
            color: var(--muted);
        }

        .footer a {
            color: var(--orange);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
        }

        .footer a:hover {
            color: var(--orange-dark);
        }

        /* ASP.NET MVC Validation styles */
        .text-danger, .field-validation-error {
            color: #EF4444;
            font-size: 12px;
            margin-top: 6px;
            display: block;
            font-weight: 500;
        }

        .validation-summary-errors {
            background-color: #FEF2F2;
            border: 1px solid #FEE2E2;
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 20px;
            color: #991B1B;
            font-size: 13px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 16px;
        }

        .validation-summary-errors li {
            margin-bottom: 4px;
        }
    </style>
</head>
<body>

<div class="card">
    <div class="logo">
        <div class="logo-mark">📚</div>
        <div class="logo-text">Neme<span>Book</span></div>
    </div>

    <h1>Create New Password</h1>
    <p class="subtitle">Choose a strong password to secure your account.</p>

    <form asp-action="@formAction" asp-controller="Account" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="Token" type="hidden" />

        <div class="field">
            <label asp-for="Password">New Password</label>
            <div class="input-wrap">
                <svg class="lock" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5zm-3 8V7a3 3 0 0 1 6 0v3H9z"/></svg>
                <input asp-for="Password" id="new-password" type="password" placeholder="Enter your password">
                <button class="toggle-eye" type="button" aria-label="Show password">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
            <div class="strength-row">
                <div class="strength-bar"><span></span></div>
                <span class="strength-label">None</span>
            </div>
        </div>

        <div class="field">
            <label asp-for="ConfirmPassword">Confirm Password</label>
            <div class="input-wrap">
                <svg class="lock" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5zm-3 8V7a3 3 0 0 1 6 0v3H9z"/></svg>
                <input asp-for="ConfirmPassword" id="confirm-password" type="password" placeholder="Confirm your password">
                <button class="toggle-eye" type="button" aria-label="Show password">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button class="submit-btn" type="submit">Reset Password</button>
    </form>

    <div class="hint">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9 12l2 2 4-4"/>
        </svg>
        <span><strong>Password Requirements:</strong> At least 8 characters including uppercase, lowercase, numbers, and symbols.</span>
    </div>

    <p class="footer">Remember your password? <a href="@Url.Action("Login", "Account")">Back to login</a></p>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

<script>
    document.querySelectorAll('.toggle-eye').forEach(btn => {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            const input = this.parentElement.querySelector('input');
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);

            const svg = this.querySelector('svg');
            if (type === 'text') {
                this.style.color = 'var(--orange)';
                svg.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></line>';
            } else {
                this.style.color = 'var(--muted)';
                svg.innerHTML = '<path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/>';
            }
        });
    });

    const passwordInput = document.getElementById('new-password');
    const strengthBarSpan = document.querySelector('.strength-bar span');
    const strengthLabel = document.querySelector('.strength-label');

    passwordInput.addEventListener('input', function () {
        const val = this.value;
        let strength = 0;
        let label = 'Very Weak';
        let color = 'var(--strength-weak)';
        let width = '10%';

        if (val.length === 0) {
            label = 'None';
            color = 'var(--border)';
            width = '0%';
        } else {
            if (val.length >= 8) strength += 1;
            if (/[A-Z]/.test(val)) strength += 1;
            if (/[a-z]/.test(val)) strength += 1;
            if (/[0-9]/.test(val)) strength += 1;
            if (/[^A-Za-z0-9]/.test(val)) strength += 1;

            if (val.length < 8) {
                label = 'Weak';
                color = '#EF4444';
                width = '30%';
            } else if (strength <= 2) {
                label = 'Weak';
                color = '#EF4444';
                width = '35%';
            } else if (strength === 3) {
                label = 'Medium';
                color = '#F59E0B';
                width = '60%';
            } else if (strength === 4) {
                label = 'Strong';
                color = '#16A34A';
                width = '85%';
            } else {
                label = 'Very Strong';
                color = '#15803D';
                width = '100%';
            }
        }

        strengthBarSpan.style.width = width;
        strengthBarSpan.style.backgroundColor = color;
        strengthLabel.textContent = label;
        strengthLabel.style.color = color;
    });

    // Trigger on initial load in case password field starts prefilled
    passwordInput.dispatchEvent(new Event('input'));
</script>
</body>
</html>
