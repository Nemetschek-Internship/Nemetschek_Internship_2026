@model Entities.ViewModels.Auth.SetPasswordViewModel

@{
    ViewData["Title"] = "Създаване на парола";
    ViewData["PasswordFormAction"] = ViewData["PasswordFormAction"]?.ToString() ?? ViewData["FormAction"]?.ToString() ?? "SetPassword";
    ViewData["PasswordFormTitle"] = "Създайте нова парола";
    ViewData["PasswordFormSubtitle"] = "Изберете силна парола, с която ще влизате в профила си.";
    ViewData["PasswordFormButtonText"] = "Потвърди паролата";
}

<partial name="_PasswordForm" model="Model" view-data="ViewData" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
