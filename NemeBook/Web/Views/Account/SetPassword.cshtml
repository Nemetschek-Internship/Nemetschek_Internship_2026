@model Entities.ViewModels.Auth.SetPasswordViewModel

@{
    ViewData["Title"] = "Set Password";
}

<style>
    .nb-auth-page {
        min-height: calc(100vh - 130px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 0;
    }

    .nb-auth-card {
        width: 100%;
        max-width: 430px;
        border-radius: 20px;
        border: 1px solid #ebecef;
        background: #ffffff;
        box-shadow: 0 12px 42px rgba(20, 25, 35, 0.1);
        padding: 24px;
    }

    .nb-brand { text-align: center; margin-bottom: 14px; }

    .nb-logo-mark {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(145deg, #f37021, #ffc14a);
        margin: 0 auto 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 32px;
        font-weight: 800;
        line-height: 1;
    }

    .nb-brand-name { font-size: 33px; font-weight: 800; line-height: 1; }
    .nb-brand-name .accent { color: #f37021; }
    .nb-auth-card h1 { text-align: center; margin: 8px 0 6px; color: #25262b; font-size: 34px; font-weight: 800; }
    .nb-subtitle { text-align: center; margin: 0 0 16px; color: #737a85; font-size: 15px; }
    .nb-form-label { display: block; color: #292d35; font-size: 14px; font-weight: 600; margin-bottom: 7px; }
    .nb-input-wrap { margin-bottom: 14px; }
    .nb-auth-input { width: 100%; height: 47px; border: 1px solid #d8dce3; border-radius: 11px; padding: 0 14px; font-size: 15px; }
    .nb-auth-input:focus { border-color: #f37021; box-shadow: 0 0 0 3px rgba(243, 112, 33, 0.14); outline: none; }
    .nb-auth-btn { width: 100%; height: 44px; border: 0; border-radius: 11px; background: #f37021; color: #fff; font-size: 20px; font-weight: 700; }
    .nb-auth-btn:hover { background: #d95f16; }
    .nb-validation { color: #b42318; font-size: 13px; margin-top: -7px; margin-bottom: 10px; display: block; }
    .nb-summary { margin-bottom: 12px; font-size: 13px; }
</style>

<div class="nb-auth-page">
    <div class="nb-auth-card">
        <div class="nb-brand">
            <div class="nb-logo-mark">n</div>
            <div class="nb-brand-name"><span class="accent">Neme</span>Book</div>
        </div>

        <h1>Set password</h1>
        <p class="nb-subtitle">Create your password to activate your account.</p>

        <form asp-action="SetPassword" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger nb-summary"></div>
            <input asp-for="Token" type="hidden" />

            <label asp-for="Password" class="nb-form-label">Password</label>
            <div class="nb-input-wrap">
                <input asp-for="Password" class="nb-auth-input" />
            </div>
            <span asp-validation-for="Password" class="nb-validation"></span>

            <label asp-for="ConfirmPassword" class="nb-form-label">Confirm password</label>
            <div class="nb-input-wrap">
                <input asp-for="ConfirmPassword" class="nb-auth-input" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="nb-validation"></span>

            <button type="submit" class="nb-auth-btn">Save password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
