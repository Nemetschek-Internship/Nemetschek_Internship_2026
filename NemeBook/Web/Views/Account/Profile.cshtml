@model Entities.ViewModels.Auth.AccountViewModel

@{
    var isTeacher = User.IsInRole("Teacher");
    Layout = "_AppShell";
    ViewData["Title"] = "Профил";
    ViewData["ActiveNav"] = "Profile";
    ViewData["ShellUserName"] = Model.FullName;
    ViewData["ShellUserMeta"] = Model.Role;
    ViewData["ShellUserInitials"] = Model.Initials;
    var homeController = Model.Role == "Ученик" ? "Student" : isTeacher ? "Teacher" : "Home";
}

@section Styles {
<style>
    .nb-profile-shell {
        min-height: 0;
        padding: 28px 34px 34px;
        background: #fbf3ec;
    }

    .nb-profile-wrap {
        width: min(100%, 980px);
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(280px, 0.82fr) minmax(360px, 1.18fr);
        gap: 20px;
    }

    .nb-profile-card,
    .nb-profile-panel {
        border: 1px solid #eee7df;
        border-radius: 14px;
        background: #ffffff;
        box-shadow: 0 14px 30px rgba(42, 35, 29, 0.06);
    }

    .nb-profile-card {
        overflow: hidden;
    }

    .nb-profile-hero {
        min-height: 210px;
        display: grid;
        align-content: end;
        justify-items: center;
        padding: 26px;
        background:
            radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.22), transparent 18%),
            linear-gradient(135deg, #ff7826 0%, #f45d0a 62%, #ed5305 100%);
        color: #ffffff;
        text-align: center;
    }

    .nb-profile-avatar {
        width: 82px;
        height: 82px;
        display: grid;
        place-items: center;
        margin-bottom: 16px;
        border: 5px solid rgba(255, 255, 255, 0.35);
        border-radius: 50%;
        background: #ffffff;
        color: #f45d0a;
        font-size: 24px;
        font-weight: 900;
    }

    .nb-profile-hero h1 {
        max-width: 100%;
        margin: 0;
        overflow: hidden;
        color: #ffffff;
        font-size: 25px;
        font-weight: 900;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-profile-role {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        margin-top: 10px;
        padding: 0 13px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.85);
        color: #e95b0c;
        font-size: 12px;
        font-weight: 900;
    }

    .nb-profile-actions {
        display: grid;
        gap: 10px;
        padding: 18px;
    }

    .nb-profile-action {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 850;
        text-decoration: none;
    }

    .nb-profile-action.is-primary {
        background: #f45d0a;
        color: #ffffff;
    }

    .nb-profile-action.is-secondary {
        background: #fff1e6;
        color: #e95b0c;
    }

    .nb-profile-panel {
        padding: 24px;
    }

    .nb-profile-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .nb-profile-heading h2 {
        margin: 0;
        color: #1f232b;
        font-size: 18px;
        font-weight: 900;
    }

    .nb-profile-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .nb-profile-field {
        min-width: 0;
        padding: 15px;
        border: 1px solid #f0e9e1;
        border-radius: 12px;
        background: #fffaf5;
    }

    .nb-profile-field.is-wide {
        grid-column: 1 / -1;
    }

    .nb-profile-field span {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 8px;
        color: #b0a79c;
        font-size: 12px;
        font-weight: 900;
    }

    .nb-profile-field span i {
        color: #f45d0a;
    }

    .nb-profile-field strong {
        display: block;
        overflow: hidden;
        color: #2a2d34;
        font-size: 15px;
        font-weight: 850;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .nb-profile-flash {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 16px;
        padding: 11px 13px;
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        background: #f0fdf4;
        color: #166534;
        font-size: 13px;
        font-weight: 800;
    }

    @@media (max-width: 820px) {
        .nb-profile-wrap {
            grid-template-columns: 1fr;
        }

        .nb-profile-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .nb-profile-shell {
            padding-left: 16px;
            padding-right: 16px;
        }
    }
</style>
}

<section class="nb-profile-shell">
<div class="nb-profile-wrap">
    <aside class="nb-profile-card">
        <div class="nb-profile-hero">
            <div class="nb-profile-avatar">@Model.Initials</div>
            <h1>@Model.FullName</h1>
            <span class="nb-profile-role">@Model.Role</span>
        </div>

        <div class="nb-profile-actions">
            <a asp-action="ChangePassword" class="nb-profile-action is-primary">
                <i class="bi bi-key-fill"></i>
                Смяна на парола
            </a>
            <a asp-action="Index" asp-controller="@homeController" class="nb-profile-action is-secondary">
                <i class="bi bi-house-fill"></i>
                Начало
            </a>
        </div>
    </aside>

    <section class="nb-profile-panel">
        @if (TempData["SuccessMessage"] is not null)
        {
            <div class="nb-profile-flash">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="nb-profile-heading">
            <h2>Профил</h2>
        </div>

        <div class="nb-profile-grid">
            <article class="nb-profile-field">
                <span><i class="bi bi-person-fill"></i>Име</span>
                <strong>@Model.FirstName</strong>
            </article>

            <article class="nb-profile-field">
                <span><i class="bi bi-person-fill"></i>Фамилия</span>
                <strong>@Model.LastName</strong>
            </article>

            <article class="nb-profile-field">
                <span><i class="bi bi-person-lines-fill"></i>Презиме</span>
                <strong>@(Model.MiddleName ?? "Не е посочено")</strong>
            </article>

            <article class="nb-profile-field">
                <span><i class="bi bi-shield-lock-fill"></i>Роля</span>
                <strong>@Model.Role</strong>
            </article>

            <article class="nb-profile-field is-wide">
                <span><i class="bi bi-envelope-fill"></i>Имейл</span>
                <strong>@Model.Email</strong>
            </article>

            <article class="nb-profile-field is-wide">
                <span><i class="bi bi-telephone-fill"></i>Телефон</span>
                <strong>@(Model.PhoneNumber ?? "Не е посочено")</strong>
            </article>
        </div>
    </section>
</div>
</section>
