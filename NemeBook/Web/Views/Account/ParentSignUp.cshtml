@model Entities.ViewModels.Auth.ParentSignUpViewModel

@{
    ViewData["Title"] = "Регистрация на родител";
}

<div class="nb-form-shell">
    <section class="nb-form-card nb-form-card-parent" aria-labelledby="parent-signup-title">
        <div class="nb-auth-brand">
            <div class="nb-auth-logo">N</div>
            <div class="nb-auth-name"><span>Neme</span>Book</div>
        </div>

        <h1 id="parent-signup-title">Завършете регистрацията</h1>
        <p class="nb-form-subtitle">Попълнете данните си и създайте парола за родителския профил.</p>

        <form asp-action="ParentSignUp" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>
            <input asp-for="Token" type="hidden" />

            <div class="nb-parent-grid">
                <div class="nb-form-field">
                    <label asp-for="FirstName" class="nb-form-label">Име <span class="nb-required-label">задължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>
                        <input asp-for="FirstName" class="nb-form-input" autocomplete="given-name" />
                    </div>
                    <span asp-validation-for="FirstName" class="nb-validation"></span>
                </div>

                <div class="nb-form-field">
                    <label asp-for="MiddleName" class="nb-form-label">Презиме <span class="nb-optional-label">незадължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>
                        <input asp-for="MiddleName" class="nb-form-input" autocomplete="additional-name" />
                    </div>
                    <span asp-validation-for="MiddleName" class="nb-validation"></span>
                </div>

                <div class="nb-form-field">
                    <label asp-for="LastName" class="nb-form-label">Фамилия <span class="nb-required-label">задължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>
                        <input asp-for="LastName" class="nb-form-input" autocomplete="family-name" />
                    </div>
                    <span asp-validation-for="LastName" class="nb-validation"></span>
                </div>

                <div class="nb-form-field">
                    <label asp-for="PhoneNumber" class="nb-form-label">Телефонен номер <span class="nb-optional-label">незадължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-telephone-fill" aria-hidden="true"></i>
                        <input asp-for="PhoneNumber" class="nb-form-input" autocomplete="tel" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="nb-validation"></span>
                </div>

                <div class="nb-form-field">
                    <label asp-for="Password" class="nb-form-label">Парола <span class="nb-required-label">задължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-lock-fill" aria-hidden="true"></i>
                        <input asp-for="Password" class="nb-form-input" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="nb-validation"></span>
                </div>

                <div class="nb-form-field">
                    <label asp-for="ConfirmPassword" class="nb-form-label">Повторете паролата <span class="nb-required-label">задължително</span></label>
                    <div class="nb-input-shell">
                        <i class="bi bi-lock-fill" aria-hidden="true"></i>
                        <input asp-for="ConfirmPassword" class="nb-form-input" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="nb-validation"></span>
                </div>
            </div>

            <button type="submit" class="nb-primary-action">Завърши регистрацията</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
