@{
    ViewData["Title"] = "Проверете имейла си";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var backAction = isAuthenticated ? "Profile" : "Login";
    var backIcon = isAuthenticated ? "bi-person" : "bi-arrow-left";
    var backText = isAuthenticated ? "Обратно към профила" : "Обратно към вход";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header text-white py-3 text-center" style="background: linear-gradient(135deg, #F97316, #EA580C);">
                <h4 class="mb-0 fw-bold"><i class="bi bi-envelope-check"></i> Проверете имейла си</h4>
            </div>
            <div class="card-body p-4 text-center">
                <div class="mb-4 text-warning" style="font-size: 4rem;">
                    <i class="bi bi-envelope-open"></i>
                </div>
                
                <h3 class="fw-bold mb-3" style="color: #1F2937;">Линкът е изпратен!</h3>
                <p class="text-muted mb-4" style="font-size: 14.5px; line-height: 1.6;">
                    Изпратихме защитен линк за смяна на паролата на вашия имейл адрес.
                    Проверете пощата си и отворете линка, за да продължите със смяната на паролата.
                </p>

                <div class="d-grid gap-2">
                    <a asp-action="@backAction" class="btn btn-secondary py-2.5" style="border-radius: 24px; font-weight: 600;">
                        <i class="bi @backIcon"></i> @backText
                    </a>
                </div>
            </div>
            <div class="card-footer text-center bg-light py-3">
                <small class="text-muted">Линкът ще изтече след 30 минути.</small>
            </div>
        </div>
    </div>
</div>
