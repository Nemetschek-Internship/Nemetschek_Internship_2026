@{
    Layout = null;
    ViewData["Title"] = "Паролата е сменена";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NemeBook - Паролата е сменена</title>
    <style>
        :root {
            --orange: #F97316;
            --orange-dark: #EA580C;
            --ink: #1F2937;
            --muted: #6B7280;
            --border: #E5E7EB;
            --bg: #F9FAFB;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--ink);
            padding: 24px;
        }

        .card {
            width: 100%;
            max-width: 360px;
            background: #fff;
            border-radius: 16px;
            padding: 32px 28px 24px;
            box-shadow: 0 8px 30px rgba(17,24,39,0.08);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            margin-bottom: 24px;
        }

        .logo-mark {
            width: 44px;
            height: 44px;
            border: 2px solid var(--orange);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-mark svg {
            width: 24px;
            height: 24px;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 700;
            color: var(--ink);
        }

        .logo-text span {
            color: var(--orange);
        }

        .badge-container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 24px;
        }

        .badge-outer {
            width: 90px;
            height: 90px;
            background-color: #FFF3E0; /* Very soft light orange background */
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .badge-inner {
            width: 62px;
            height: 62px;
            background-color: var(--orange);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            box-shadow: 0 4px 14px rgba(249, 115, 22, 0.25);
        }

        .badge-inner svg {
            width: 32px;
            height: 32px;
        }

        h1 {
            font-size: 22px;
            font-weight: 700;
            text-align: center;
            margin: 0 0 10px;
            color: var(--ink);
        }

        .subtitle {
            text-align: center;
            color: var(--muted);
            font-size: 13.5px;
            line-height: 1.5;
            margin: 0 0 24px;
            padding: 0 10px;
        }

        .submit-btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 24px;
            background: linear-gradient(180deg, var(--orange), var(--orange-dark));
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 6px 16px rgba(234,88,12,0.35);
            transition: transform .15s ease, box-shadow .15s ease;
            text-decoration: none;
            text-align: center;
            display: block;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(234,88,12,0.4);
        }

        .footer-note {
            text-align: center;
            margin-top: 24px;
            font-size: 11.5px;
            color: var(--muted);
            letter-spacing: 0.2px;
        }
    </style>
</head>
<body>

<div class="card">
    <div class="logo">
        <div class="logo-mark">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 20V4h3.2L16 15.5V4h4v16h-3.2L8 8.5V20H4z" fill="#F97316"/>
            </svg>
        </div>
        <div class="logo-text">Neme<span>Book</span></div>
    </div>

    <div class="badge-container">
        <div class="badge-outer">
            <div class="badge-inner">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
        </div>
    </div>

    <h1>Паролата е сменена!</h1>
    <p class="subtitle">Вече можете да влезете в училищния си профил с новата парола.</p>

    <a href="@Url.Action("Login", "Account")" class="submit-btn">Обратно към вход</a>

    <div class="footer-note">
        Сигурно. Лесно. Умно. Създадено за училища.
    </div>
</div>

</body>
</html>
