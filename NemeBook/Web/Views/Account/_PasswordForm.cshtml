@model Entities.ViewModels.Auth.PasswordFormViewModel

@{
    var actionName = ViewData["PasswordFormAction"]?.ToString() ?? string.Empty;
    var title = ViewData["PasswordFormTitle"]?.ToString() ?? "Създайте нова парола";
    var subtitle = ViewData["PasswordFormSubtitle"]?.ToString() ?? "Изберете силна парола, с която ще влизате в профила си.";
    var buttonText = ViewData["PasswordFormButtonText"]?.ToString() ?? "Потвърди паролата";
}

<div class="nb-login-page">
    <aside class="nb-login-brand-panel" aria-hidden="true">
        <div class="nb-login-brand-content">
            <div class="nb-login-brand-orb"></div>
            <div class="nb-login-wordmark"><span>Neme</span>Book</div>
            <p>Създайте сигурна парола за достъп до училищния си профил.</p>
        </div>
    </aside>

    <main class="nb-login-card-area">
    <section class="nb-login-panel" aria-labelledby="password-form-title">
        <h1 id="password-form-title">@title</h1>
        <p class="nb-login-subtitle">@subtitle</p>

        <form asp-action="@actionName" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>
            <input asp-for="Token" type="hidden" />

            <div class="nb-form-field">
                <label asp-for="Password" class="nb-form-label">Нова парола</label>
                <div class="nb-input-shell">
                    <i class="bi bi-lock-fill" aria-hidden="true"></i>
                    <input asp-for="Password" id="passwordInput" class="nb-form-input nb-password-input" autocomplete="new-password" />
                    <button type="button" class="nb-password-toggle" data-password-toggle="passwordInput" aria-label="Покажи паролата">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="nb-password-strength" aria-live="polite">
                    <div class="nb-password-strength-track">
                        <span id="passwordStrengthBar" class="nb-password-strength-bar"></span>
                    </div>
                    <span id="passwordStrengthText" class="nb-password-strength-text">Въведете поне 8 символа.</span>
                </div>
                <span asp-validation-for="Password" class="nb-validation"></span>
            </div>

            <div class="nb-form-field">
                <label asp-for="ConfirmPassword" class="nb-form-label">Повторете паролата</label>
                <div class="nb-input-shell">
                    <i class="bi bi-lock-fill" aria-hidden="true"></i>
                    <input asp-for="ConfirmPassword" id="confirmPasswordInput" class="nb-form-input nb-password-input" autocomplete="new-password" />
                    <button type="button" class="nb-password-toggle" data-password-toggle="confirmPasswordInput" aria-label="Покажи паролата">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="nb-validation"></span>
            </div>

            <button type="submit" class="nb-primary-action">@buttonText</button>

            <p class="nb-form-note">
                <i class="bi bi-check-circle" aria-hidden="true"></i>
                Използвайте поне 8 символа, главна буква, малка буква, цифра и специален символ.
            </p>
        </form>
    </section>
    </main>
</div>

<script>
    (function () {
        const passwordInput = document.getElementById('passwordInput');
        const strengthBar = document.getElementById('passwordStrengthBar');
        const strengthText = document.getElementById('passwordStrengthText');

        const states = [
            { className: '', text: 'Въведете поне 8 символа.' },
            { className: 'is-weak', text: 'Слаба парола' },
            { className: 'is-fair', text: 'Средна парола' },
            { className: 'is-good', text: 'Добра парола' },
            { className: 'is-strong', text: 'Силна парола' }
        ];

        function scorePassword(value) {
            if (!value) {
                return 0;
            }

            let score = value.length >= 8 ? 1 : 0;
            score += /[a-zа-я]/.test(value) ? 1 : 0;
            score += /[A-ZА-Я]/.test(value) ? 1 : 0;
            score += /\d/.test(value) ? 1 : 0;
            score += /[^a-zA-Zа-яА-Я0-9]/.test(value) ? 1 : 0;

            return Math.min(4, score);
        }

        function updateStrength() {
            const state = states[scorePassword(passwordInput.value)];
            strengthBar.className = 'nb-password-strength-bar';
            if (state.className) {
                strengthBar.classList.add(state.className);
            }

            strengthText.textContent = state.text;
        }

        document.querySelectorAll('[data-password-toggle]').forEach(function (toggle) {
            const input = document.getElementById(toggle.dataset.passwordToggle);
            const icon = toggle.querySelector('i');

            toggle.addEventListener('click', function () {
                const showPassword = input.type === 'password';
                input.type = showPassword ? 'text' : 'password';
                icon.classList.toggle('bi-eye', !showPassword);
                icon.classList.toggle('bi-eye-slash', showPassword);
                toggle.setAttribute('aria-label', showPassword ? 'Скрий паролата' : 'Покажи паролата');
            });
        });

        passwordInput.addEventListener('input', updateStrength);
        updateStrength();
    })();
</script>
