<!-- Web/Views/Account/ChangePassword.cshtml -->
@model Entities.ViewModels.Auth.ResetPasswordRequest

@{
    ViewData["Title"] = "Смяна на парола";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header text-white py-3 text-center" style="background: linear-gradient(135deg, #F97316, #EA580C);">
                <h4 class="mb-0 fw-bold"><i class="bi bi-key"></i> Смяна на парола</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePasswordConfirm" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" name="token" value="@ViewData["Token"]" />

                    <p class="text-muted mb-4" style="font-size: 14px;">
                        Въведете новата си парола. Изберете силна и уникална парола.
                    </p>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label fw-bold">Нова парола</label>
                        <div class="input-group" style="border-radius: 8px; overflow: hidden;">
                            <span class="input-group-text" style="background-color: #f3f4f6; border: 1px solid #e5e7eb;">
                                <i class="bi bi-key" style="color: #F97316;"></i>
                            </span>
                            <input asp-for="NewPassword" 
                                   class="form-control" 
                                   type="password" 
                                   placeholder="Въведете нова парола"
                                   style="border: 1px solid #e5e7eb;" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold">Потвърдете паролата</label>
                        <div class="input-group" style="border-radius: 8px; overflow: hidden;">
                            <span class="input-group-text" style="background-color: #f3f4f6; border: 1px solid #e5e7eb;">
                                <i class="bi bi-key" style="color: #F97316;"></i>
                            </span>
                            <input asp-for="ConfirmPassword" 
                                   class="form-control" 
                                   type="password" 
                                   placeholder="Потвърдете новата парола"
                                   style="border: 1px solid #e5e7eb;" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="alert alert-info d-flex gap-2" role="alert">
                        <i class="bi bi-info-circle-fill flex-shrink-0" style="color: #0066cc;"></i>
                        <div>
                            <strong>Изисквания към паролата:</strong>
                            <ul class="mb-0 mt-2 ps-3" style="font-size: 13px;">
                                <li>Поне 8 символа</li>
                                <li>Комбинация от главни и малки букви</li>
                                <li>Включете цифри и символи</li>
                            </ul>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn" style="background: linear-gradient(135deg, #F97316, #EA580C); color: white; border: none; font-weight: 600; padding: 10px 16px; border-radius: 8px;">
                            <i class="bi bi-check-circle"></i> Смени паролата
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Обратно към профила
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
