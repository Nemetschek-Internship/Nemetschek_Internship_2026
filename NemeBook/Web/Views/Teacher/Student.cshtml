@model Entities.ViewModels.Teachers.TeacherStudentDetailsViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = Model.StudentName;
    ViewData["ActiveNav"] = User.IsInRole("Principal") ? "Classes" : "MyClass";
    ViewData["ShellUserName"] = Model.TeacherName;
    ViewData["ShellUserMeta"] = Model.MainMeta;
    ViewData["ShellUserInitials"] = Model.TeacherInitials;

    var overallAverage = Model.Grades.Count > 0 ? Model.Grades.Average(grade => grade.Value) : 0m;
    var excellentGrades = Model.Grades.Count(grade => grade.DisplayValue >= 5);
    var lowGrades = Model.Grades.Count(grade => grade.DisplayValue <= 3);
    var excusedAbsences = Model.Absences.Count(absence => absence.IsExcused);
    var unexcusedAbsences = Model.Absences.Count - excusedAbsences;
    var praiseCount = Model.Feedbacks.Count(feedback => feedback.TypeName.Contains("похвал", StringComparison.OrdinalIgnoreCase));
    var noteCount = Math.Max(0, Model.Feedbacks.Count - praiseCount);
    var subjectStats = Model.Grades.Select(grade => grade.SubjectName)
        .Concat(Model.Absences.Select(absence => absence.SubjectName))
        .Concat(Model.Feedbacks.Select(feedback => feedback.SubjectName))
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .Select(subject => new
        {
            Name = subject,
            Grades = Model.Grades.Where(grade => string.Equals(grade.SubjectName, subject, StringComparison.OrdinalIgnoreCase)).ToArray(),
            Absences = Model.Absences.Count(absence => string.Equals(absence.SubjectName, subject, StringComparison.OrdinalIgnoreCase)),
            Feedbacks = Model.Feedbacks.Count(feedback => string.Equals(feedback.SubjectName, subject, StringComparison.OrdinalIgnoreCase))
        })
        .ToArray();
}

@section Styles {
<style>
    .nb-student-details-page {
        min-width: 0;
        display: grid;
        gap: 18px;
        padding: 28px 34px 44px;
    }
    .nb-student-details-hero,
    .nb-stat-card,
    .nb-stats-panel {
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
    }
    .nb-student-details-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 18px;
        padding: 20px;
    }
    .nb-student-identity {
        min-width: 0;
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr);
        align-items: center;
        gap: 12px;
    }
    .nb-student-avatar {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #ffe4c2;
        color: #a95508;
        font-size: 13px;
        font-weight: 950;
    }
    .nb-student-identity h1 {
        margin: 0;
        overflow: hidden;
        color: #1f232b;
        font-size: 22px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-student-identity p {
        margin: 4px 0 0;
        color: #8f887f;
        font-size: 12px;
        font-weight: 850;
    }
    .nb-student-details-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }
    .nb-student-link {
        min-height: 34px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0 12px;
        border-radius: 7px;
        background: #fbf7f2;
        color: #6f6962;
        font-size: 12px;
        font-weight: 900;
        text-decoration: none;
    }
    .nb-student-link.is-primary {
        background: #ffe4c2;
        color: #f97316;
    }
    .nb-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }
    .nb-stat-card {
        min-width: 0;
        display: grid;
        gap: 8px;
        padding: 16px;
    }
    .nb-stat-card span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
    }
    .nb-stat-card strong {
        color: #20232a;
        font-size: 26px;
        font-weight: 950;
        line-height: 1;
    }
    .nb-stat-card small {
        overflow: hidden;
        color: #6f6962;
        font-size: 12px;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-stats-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
        gap: 18px;
    }
    .nb-stats-panel {
        min-width: 0;
        overflow: hidden;
    }
    .nb-stats-panel header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 16px 18px;
        border-bottom: 1px solid #f0e8df;
    }
    .nb-stats-panel h2 {
        margin: 0;
        color: #20232a;
        font-size: 16px;
        font-weight: 950;
    }
    .nb-stats-panel header span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
    }
    .nb-subject-stat-list,
    .nb-distribution-list {
        display: grid;
        gap: 0;
    }
    .nb-subject-stat-row,
    .nb-distribution-row {
        min-width: 0;
        display: grid;
        gap: 8px;
        padding: 14px 18px;
        border-bottom: 1px solid #f5eee7;
    }
    .nb-subject-stat-row:last-child,
    .nb-distribution-row:last-child {
        border-bottom: 0;
    }
    .nb-subject-stat-main,
    .nb-distribution-main {
        min-width: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
    }
    .nb-subject-stat-main strong,
    .nb-distribution-main strong {
        overflow: hidden;
        color: #20232a;
        font-size: 13px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-subject-stat-main span,
    .nb-distribution-main span {
        color: #f97316;
        font-size: 12px;
        font-weight: 950;
    }
    .nb-track {
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: #f2eee8;
    }
    .nb-track span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #f97316;
    }
    .nb-subject-stat-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .nb-chip {
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        padding: 0 8px;
        border-radius: 7px;
        background: #fbf7f2;
        color: #6f6962;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-chip.is-red {
        background: #ffe0dc;
        color: #c23329;
    }
    .nb-chip.is-green {
        background: #dff8e9;
        color: #159953;
    }
    .nb-empty-stats {
        min-height: 150px;
        display: grid;
        place-items: center;
        padding: 18px;
        color: #8f887f;
        font-size: 13px;
        font-weight: 850;
        text-align: center;
    }
    @@media (max-width: 1100px) {
        .nb-stat-grid,
        .nb-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    @@media (max-width: 760px) {
        .nb-student-details-page {
            padding: 18px;
        }
        .nb-student-details-hero,
        .nb-stat-grid,
        .nb-stats-grid {
            grid-template-columns: 1fr;
        }
        .nb-student-details-actions {
            justify-content: flex-start;
        }
        .nb-student-identity h1 {
            white-space: normal;
        }
    }
</style>
}

<section class="nb-student-details-page">
    <header class="nb-student-details-hero">
        <div class="nb-student-identity">
            <span class="nb-student-avatar" aria-hidden="true">@Model.StudentInitials</span>
            <div>
                <h1>@Model.StudentName</h1>
                <p>Клас @Model.ClassName</p>
            </div>
        </div>

        <nav class="nb-student-details-actions" aria-label="Действия">
            @if (User.IsInRole("Principal"))
            {
                <a class="nb-student-link" asp-controller="ClassManagement" asp-action="Students" asp-route-classId="@Model.ClassId">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i>
                    <span>Назад</span>
                </a>
            }
            else
            {
                <a class="nb-student-link" asp-controller="Teacher" asp-action="MyClass" asp-route-classId="@Model.ClassId">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i>
                    <span>Назад</span>
                </a>
            }
            <a class="nb-student-link is-primary" href="@Url.Content($"~/Grade/StudentGrades?studentId={Model.StudentId}")">
                <i class="bi bi-journal-check" aria-hidden="true"></i>
                <span>Всички оценки</span>
            </a>
            <a class="nb-student-link is-primary" asp-controller="Teacher" asp-action="StudentFeedbacks" asp-route-studentId="@Model.StudentId">
                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                <span>Всички отзиви</span>
            </a>
            <a class="nb-student-link is-primary" asp-controller="Teacher" asp-action="StudentAbsences" asp-route-studentId="@Model.StudentId">
                <i class="bi bi-person-x" aria-hidden="true"></i>
                <span>Всички отсъствия</span>
            </a>
        </nav>
    </header>

    <section class="nb-stat-grid" aria-label="Обща статистика">
        <article class="nb-stat-card">
            <span>Среден успех</span>
            <strong>@overallAverage.ToString("0.00")</strong>
            <small>@Model.Grades.Count оценки общо</small>
        </article>
        <article class="nb-stat-card">
            <span>Силни оценки</span>
            <strong>@excellentGrades</strong>
            <small>Оценки 5 и 6</small>
        </article>
        <article class="nb-stat-card">
            <span>Отсъствия</span>
            <strong>@Model.Absences.Count</strong>
            <small>@unexcusedAbsences неизвинени · @excusedAbsences извинени</small>
        </article>
        <article class="nb-stat-card">
            <span>Отзиви</span>
            <strong>@Model.Feedbacks.Count</strong>
            <small>@praiseCount положителни · @noteCount други</small>
        </article>
    </section>

    <section class="nb-stats-grid">
        <article class="nb-stats-panel">
            <header>
                <h2>Предмети</h2>
                <span>@subjectStats.Length предмета</span>
            </header>
            @if (subjectStats.Length == 0)
            {
                <div class="nb-empty-stats">Все още няма въведени данни за този ученик.</div>
            }
            else
            {
                <div class="nb-subject-stat-list">
                    @foreach (var subject in subjectStats)
                    {
                        var average = subject.Grades.Length > 0 ? subject.Grades.Average(grade => grade.Value) : 0m;
                        var averageText = average.ToString("0.00");
                        var progress = subject.Grades.Length > 0 ? Math.Clamp((int)Math.Round(average / 6m * 100m), 0, 100) : 0;
                        <section class="nb-subject-stat-row">
                            <div class="nb-subject-stat-main">
                                <strong>@subject.Name</strong>
                                <span>@(subject.Grades.Length > 0 ? averageText : "няма")</span>
                            </div>
                            <div class="nb-track" aria-label="Среден успех @averageText">
                                <span style="width: @progress%"></span>
                            </div>
                            <div class="nb-subject-stat-meta">
                                <span class="nb-chip">@subject.Grades.Length оценки</span>
                                <span class="nb-chip @(subject.Absences > 0 ? "is-red" : null)">@subject.Absences отсъствия</span>
                                <span class="nb-chip">@subject.Feedbacks отзиви</span>
                            </div>
                        </section>
                    }
                </div>
            }
        </article>

        <aside class="nb-stats-panel">
            <header>
                <h2>Разпределение</h2>
                <span>бърз преглед</span>
            </header>
            <div class="nb-distribution-list">
                @{
                    var goodProgress = Model.Grades.Count > 0 ? Math.Clamp((int)Math.Round(excellentGrades / (decimal)Model.Grades.Count * 100m), 0, 100) : 0;
                    var lowProgress = Model.Grades.Count > 0 ? Math.Clamp((int)Math.Round(lowGrades / (decimal)Model.Grades.Count * 100m), 0, 100) : 0;
                    var excusedProgress = Model.Absences.Count > 0 ? Math.Clamp((int)Math.Round(excusedAbsences / (decimal)Model.Absences.Count * 100m), 0, 100) : 0;
                    var praiseProgress = Model.Feedbacks.Count > 0 ? Math.Clamp((int)Math.Round(praiseCount / (decimal)Model.Feedbacks.Count * 100m), 0, 100) : 0;
                }
                <section class="nb-distribution-row">
                    <div class="nb-distribution-main">
                        <strong>Оценки 5 и 6</strong>
                        <span>@excellentGrades</span>
                    </div>
                    <div class="nb-track"><span style="width: @goodProgress%"></span></div>
                </section>
                <section class="nb-distribution-row">
                    <div class="nb-distribution-main">
                        <strong>Оценки 2 и 3</strong>
                        <span>@lowGrades</span>
                    </div>
                    <div class="nb-track"><span style="width: @lowProgress%"></span></div>
                </section>
                <section class="nb-distribution-row">
                    <div class="nb-distribution-main">
                        <strong>Извинени отсъствия</strong>
                        <span>@excusedAbsences</span>
                    </div>
                    <div class="nb-track"><span style="width: @excusedProgress%"></span></div>
                </section>
                <section class="nb-distribution-row">
                    <div class="nb-distribution-main">
                        <strong>Положителни отзиви</strong>
                        <span>@praiseCount</span>
                    </div>
                    <div class="nb-track"><span style="width: @praiseProgress%"></span></div>
                </section>
            </div>
        </aside>
    </section>
</section>
