@model Entities.ViewModels.Teachers.TeacherHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Моите класове";
    ViewData["ActiveNav"] = "MyClass";
    ViewData["ShellUserName"] = Model.TeacherName;
    ViewData["ShellUserMeta"] = Model.MainMeta;
    ViewData["ShellUserInitials"] = Model.TeacherInitials;
}

@section Styles {
<style>
    .nb-teacher-classes-page {
        min-width: 0;
        padding: 28px 34px 44px;
    }

    .nb-classes-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 20px;
    }

    .nb-classes-header h2 {
        margin: 0;
        color: #20232a;
        font-size: 22px;
        font-weight: 950;
    }

    .nb-classes-header p {
        margin: 6px 0 0;
        color: #8f887f;
        font-size: 13px;
        font-weight: 800;
    }

    .nb-class-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 14px;
    }

    .nb-class-card {
        min-height: 142px;
        display: grid;
        align-content: space-between;
        gap: 18px;
        padding: 18px;
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        color: inherit;
        text-decoration: none;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
        transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nb-class-card:hover,
    .nb-class-card:focus-visible {
        border-color: #f97316;
        box-shadow: 0 14px 30px rgba(42, 35, 29, 0.09);
        outline: none;
        transform: translateY(-1px);
    }

    .nb-class-card-top {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 12px;
    }

    .nb-class-card h3 {
        margin: 0;
        color: #1f232b;
        font-size: 28px;
        font-weight: 950;
        line-height: 1;
    }

    .nb-main-class-pill {
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        border-radius: 999px;
        background: #ffe4c2;
        color: #d95f0b;
        font-size: 11px;
        font-weight: 950;
        white-space: nowrap;
    }

    .nb-class-card p {
        margin: 0;
        color: #6f6962;
        font-size: 13px;
        font-weight: 850;
        line-height: 1.35;
    }

    .nb-class-card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: #9b948b;
        font-size: 12px;
        font-weight: 850;
    }

    .nb-class-card-meta i {
        color: #f97316;
    }

    .nb-empty-class-picker {
        min-height: 180px;
        display: grid;
        place-items: center;
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        color: #8f887f;
        font-size: 14px;
        font-weight: 850;
        text-align: center;
    }

    @@media (max-width: 640px) {
        .nb-teacher-classes-page {
            padding: 18px;
        }

        .nb-classes-header {
            display: grid;
        }
    }
</style>
}

<section class="nb-teacher-classes-page" aria-label="Моите класове">
    <header class="nb-classes-header">
        <div>
            <h2>Изберете клас</h2>
            <p>Класове, в които преподавате или сте класен ръководител.</p>
        </div>
    </header>

    @if (Model.TeachingClasses.Count == 0)
    {
        <div class="nb-empty-class-picker">Няма назначени класове.</div>
    }
    else
    {
        <div class="nb-class-card-grid">
            @foreach (var schoolClass in Model.TeachingClasses)
            {
                <a class="nb-class-card"
                   asp-controller="Teacher"
                   asp-action="MyClass"
                   asp-route-classId="@schoolClass.Id">
                    <span class="nb-class-card-top">
                        <span>
                            <h3>@schoolClass.Name</h3>
                        </span>
                        @if (schoolClass.IsMainClass)
                        {
                            <span class="nb-main-class-pill">моят клас</span>
                        }
                    </span>
                    <p title="@schoolClass.SubjectNames">@schoolClass.SubjectNames</p>
                    <span class="nb-class-card-meta">
                        <span>@schoolClass.StudentCount ученици</span>
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </span>
                </a>
            }
        </div>
    }
</section>
