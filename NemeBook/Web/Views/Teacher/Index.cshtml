@model Entities.ViewModels.Teachers.TeacherHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Начало";
    ViewData["ActiveNav"] = "Home";
    ViewData["ShellUserName"] = Model.TeacherName;
    ViewData["ShellUserMeta"] = Model.MainMeta;
    ViewData["ShellUserInitials"] = Model.TeacherInitials;

    var classes = Model.TeachingClasses.OrderBy(schoolClass => schoolClass.Name).ToArray();
    var subjects = Model.TeachingSubjects
        .OrderBy(subject => subject.ClassName)
        .ThenBy(subject => subject.SubjectName)
        .ToArray();
    var focusStudents = Model.Students
        .OrderByDescending(student => student.RecordCount)
        .ThenBy(student => student.FullName)
        .Take(5)
        .ToArray();
    var busiestClass = classes
        .OrderByDescending(schoolClass => schoolClass.StudentCount)
        .FirstOrDefault();
}

@section Styles {
<style>
    .nb-teacher-dashboard {
        min-width: 0;
        display: grid;
        gap: 18px;
        padding: 28px 34px 44px;
    }
    .nb-teacher-hero,
    .nb-teacher-card,
    .nb-teacher-panel {
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
    }
    .nb-teacher-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 18px;
        padding: 20px;
        overflow: hidden;
    }
    .nb-teacher-title {
        min-width: 0;
        display: grid;
        grid-template-columns: 52px minmax(0, 1fr);
        align-items: center;
        gap: 13px;
    }
    .nb-teacher-avatar {
        width: 52px;
        height: 52px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #ffe4c2;
        color: #a95508;
        font-size: 14px;
        font-weight: 950;
    }
    .nb-teacher-title h1 {
        margin: 0;
        overflow: hidden;
        color: #1f232b;
        font-size: 23px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-teacher-title p {
        margin: 5px 0 0;
        color: #8f887f;
        font-size: 12px;
        font-weight: 850;
    }
    .nb-teacher-hero-note {
        max-width: 290px;
        color: #6f6962;
        font-size: 12px;
        font-weight: 850;
        line-height: 1.45;
        text-align: right;
    }
    .nb-teacher-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }
    .nb-teacher-card {
        min-width: 0;
        display: grid;
        gap: 9px;
        padding: 16px;
    }
    .nb-teacher-card span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
    }
    .nb-teacher-card strong {
        color: #20232a;
        font-size: 28px;
        font-weight: 950;
        line-height: 1;
    }
    .nb-teacher-card small {
        overflow: hidden;
        color: #6f6962;
        font-size: 12px;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-teacher-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        gap: 18px;
    }
    .nb-teacher-panel {
        min-width: 0;
        overflow: hidden;
    }
    .nb-teacher-panel header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 18px;
        border-bottom: 1px solid #f0e8df;
    }
    .nb-teacher-panel h2 {
        margin: 0;
        color: #20232a;
        font-size: 16px;
        font-weight: 950;
    }
    .nb-teacher-panel header span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
    }
    .nb-load-list,
    .nb-focus-list,
    .nb-subject-cloud {
        display: grid;
    }
    .nb-load-row,
    .nb-focus-row {
        min-width: 0;
        display: grid;
        gap: 8px;
        padding: 14px 18px;
        border-bottom: 1px solid #f5eee7;
    }
    .nb-load-row:last-child,
    .nb-focus-row:last-child {
        border-bottom: 0;
    }
    .nb-load-main,
    .nb-focus-main {
        min-width: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
    }
    .nb-load-main strong,
    .nb-focus-main strong {
        overflow: hidden;
        color: #20232a;
        font-size: 13px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-pill {
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        background: #fbf7f2;
        color: #6f6962;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-pill.is-warm {
        background: #ffe4c2;
        color: #f97316;
    }
    .nb-pill.is-green {
        background: #dff8e9;
        color: #159953;
    }
    .nb-load-subjects {
        overflow: hidden;
        color: #8f887f;
        font-size: 12px;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-subject-cloud {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
        padding: 18px;
    }
    .nb-subject-tile {
        min-width: 0;
        display: grid;
        gap: 5px;
        padding: 12px;
        border-radius: 8px;
        background: #fbf7f2;
    }
    .nb-subject-tile strong {
        overflow: hidden;
        color: #20232a;
        font-size: 12px;
        font-weight: 950;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .nb-subject-tile span {
        color: #8f887f;
        font-size: 11px;
        font-weight: 850;
    }
    .nb-empty-panel {
        min-height: 130px;
        display: grid;
        place-items: center;
        padding: 18px;
        color: #8f887f;
        font-size: 13px;
        font-weight: 850;
        text-align: center;
    }
    @@media (max-width: 1080px) {
        .nb-teacher-stat-grid,
        .nb-teacher-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    @@media (max-width: 720px) {
        .nb-teacher-dashboard {
            padding: 18px;
        }
        .nb-teacher-hero,
        .nb-teacher-stat-grid,
        .nb-teacher-grid {
            grid-template-columns: 1fr;
        }
        .nb-teacher-hero-note {
            max-width: none;
            text-align: left;
        }
        .nb-teacher-title h1 {
            white-space: normal;
        }
    }
</style>
}

<section class="nb-teacher-dashboard" aria-label="Начало за учител">
    <header class="nb-teacher-hero">
        <div class="nb-teacher-title">
            <span class="nb-teacher-avatar" aria-hidden="true">@Model.TeacherInitials</span>
            <div>
                <h1>@Model.TeacherName</h1>
                <p>@Model.MainMeta</p>
            </div>
        </div>
        <p class="nb-teacher-hero-note">
            Обобщение на натоварването, покритието по класове и учениците с най-много записи.
        </p>
    </header>

    <section class="nb-teacher-stat-grid" aria-label="Обобщение">
        <article class="nb-teacher-card">
            <span>Класове</span>
            <strong>@classes.Length</strong>
            <small>@(Model.HasMainClass ? $"Класен на {Model.ClassName}" : "Без поверен клас")</small>
        </article>
        <article class="nb-teacher-card">
            <span>Предмети</span>
            <strong>@subjects.Select(subject => subject.SubjectName).Distinct().Count()</strong>
            <small>@subjects.Length разпределения</small>
        </article>
        <article class="nb-teacher-card">
            <span>Ученици</span>
            <strong>@Model.StudentCount</strong>
            <small>@(busiestClass is null ? "Няма класове" : $"Най-голям: {busiestClass.Name}")</small>
        </article>
        <article class="nb-teacher-card">
            <span>Фокус</span>
            <strong>@focusStudents.Count(student => student.RecordCount > 0)</strong>
            <small>ученици със записи</small>
        </article>
    </section>

    <section class="nb-teacher-grid">
        <article class="nb-teacher-panel">
            <header>
                <h2>Покритие по класове</h2>
                <span>@classes.Length класа</span>
            </header>
            @if (classes.Length == 0)
            {
                <div class="nb-empty-panel">Все още няма назначени класове.</div>
            }
            else
            {
                <div class="nb-load-list">
                    @foreach (var schoolClass in classes)
                    {
                        <section class="nb-load-row">
                            <div class="nb-load-main">
                                <strong>Клас @schoolClass.Name</strong>
                                <span class="nb-pill @(schoolClass.IsMainClass ? "is-warm" : null)">
                                    @(schoolClass.IsMainClass ? "класен" : $"{schoolClass.StudentCount} ученици")
                                </span>
                            </div>
                            <span class="nb-load-subjects" title="@schoolClass.SubjectNames">
                                @(string.IsNullOrWhiteSpace(schoolClass.SubjectNames) ? "Няма предмети" : schoolClass.SubjectNames)
                            </span>
                        </section>
                    }
                </div>
            }
        </article>

        <article class="nb-teacher-panel">
            <header>
                <h2>Фокус ученици</h2>
                <span>@focusStudents.Length показани</span>
            </header>
            @if (focusStudents.Length == 0)
            {
                <div class="nb-empty-panel">Няма ученици за показване.</div>
            }
            else
            {
                <div class="nb-focus-list">
                    @foreach (var student in focusStudents)
                    {
                        <section class="nb-focus-row">
                            <div class="nb-focus-main">
                                <strong>@student.FullName</strong>
                                <span class="nb-pill @(student.RecordCount > 0 ? "is-green" : null)">
                                    @student.RecordCount записи
                                </span>
                            </div>
                        </section>
                    }
                </div>
            }
        </article>
    </section>

    <article class="nb-teacher-panel">
        <header>
            <h2>Предмети и класове</h2>
            <span>@subjects.Length разпределения</span>
        </header>
        @if (subjects.Length == 0)
        {
            <div class="nb-empty-panel">Все още няма назначени предмети.</div>
        }
        else
        {
            <div class="nb-subject-cloud">
                @foreach (var subject in subjects)
                {
                    <section class="nb-subject-tile">
                        <strong>@subject.SubjectName</strong>
                        <span>Клас @subject.ClassName · @subject.StudentCount ученици</span>
                    </section>
                }
            </div>
        }
    </article>
</section>
