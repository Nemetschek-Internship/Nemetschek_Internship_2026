@{
    var isAdminShell = User.IsInRole("Principal");
    var bodyClass = "nb-principal-body";
    var shellClass = $"nb-principal-shell {ViewData["ShellClass"]}".Trim();
    var mainClass = $"nb-principal-main {ViewData["MainClass"]}".Trim();
    var topbarClass = "nb-principal-topbar";
    var topActionsClass = "nb-principal-top-actions";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f97316" />
    <title>@ViewData["Title"] - NemeBook</title>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@bodyClass">
    <div class="@shellClass">
        <partial name="~/Views/Shared/Components/Navigation/_RoleSideNav.cshtml" />

        <main class="@mainClass"
              data-current-user-id="@ViewData["ShellCurrentUserId"]"
              data-current-user-name="@ViewData["ShellCurrentUserName"]"
              data-pending-target-user-id="@ViewData["ShellPendingTargetUserId"]">
            <header class="@topbarClass">
                <h1>@ViewData["Title"]</h1>

                @if (IsSectionDefined("TopbarCenter"))
                {
                    @await RenderSectionAsync("TopbarCenter", required: false)
                }
                else if (isAdminShell)
                {
                    <partial name="~/Views/Shared/Components/Admin/_AdminStudentSearch.cshtml" />
                }

                <div class="@topActionsClass">
                    @if (IsSectionDefined("TopbarActions"))
                    {
                        @await RenderSectionAsync("TopbarActions", required: false)
                    }
                    else if (isAdminShell)
                    {
                        <form asp-action="Logout" asp-area="" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            <button class="nb-principal-action-btn is-logout" type="submit">
                                <span>Изход</span>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="nb-principal-action-btn is-logout" type="submit">
                                <span>Изход</span>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            </button>
                        </form>
                    }
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/microsoft-signalr/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/pwa.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
