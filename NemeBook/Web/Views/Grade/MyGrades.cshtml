@model Entities.ViewModels.Grades.StudentGradesViewModel

@{
    ViewData["Title"] = "Academics";

    string GetGradeClass(decimal value) => value >= 5 ? "nb-grade-good" : value >= 4 ? "nb-grade-mid" : "nb-grade-bad";
    string GetStatusClass(Entities.Enums.AbsenceStatus status) => status == Entities.Enums.AbsenceStatus.Excused ? "nb-pill-success" : "nb-pill-danger";
    string GetTypeClass(Entities.Enums.AbsenceType type) => type == Entities.Enums.AbsenceType.Lateness ? "nb-pill-warning" : "nb-pill-success";
    var recentSubjects = Model.GradesBySubject.Take(6).ToList();
    var recentFeedback = ViewBag.RecentFeedback as IEnumerable<dynamic>;
    var recentAbsences = ViewBag.RecentAbsences as IEnumerable<dynamic>;
}

<div class="nb-student-dashboard">
    <section class="nb-dashboard-grid">
        <article class="nb-card nb-grades-card">
            <div class="nb-card-header">
                <h2>Grades</h2>
            </div>

            <div class="nb-grades-list">
                @foreach (var subject in recentSubjects)
                {
                    var subjectName = subject.Key;
                    var grades = subject.Value.OrderByDescending(g => g.Date).Take(3).ToList();
                    var average = Model.AverageBySubject.GetValueOrDefault(subjectName, 0m);

                    <div class="nb-grade-row">
                        <div class="nb-grade-subject">
                            <div class="nb-subject-icon" aria-hidden="true"></div>
                            <div class="nb-subject-text">
                                <div class="nb-subject-name">@subjectName</div>
                            </div>
                        </div>

                        <div class="nb-grade-meta">
                            @foreach (var grade in grades)
                            {
                                <span class="nb-grade-badge @GetGradeClass(grade.Value)">@grade.Value.ToString("0")</span>
                            }

                            <span class="nb-average-badge">@average.ToString("0.0")</span>
                        </div>
                    </div>
                }
            </div>
        </article>

        <div class="nb-side-stack">
            <article class="nb-card">
                <div class="nb-card-header">
                    <h2>Feedback</h2>
                </div>

                <div class="nb-summary-list">
                    @if (recentFeedback is not null && recentFeedback.Any())
                    {
                        foreach (var item in recentFeedback)
                        {
                            <div class="nb-summary-row">
                                <span class="nb-pill-success">Good mark</span>
                                <div class="nb-summary-line"></div>
                                <div class="nb-summary-line short"></div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="nb-empty-state">No feedback data available.</div>
                    }
                </div>
            </article>

            <article class="nb-card">
                <div class="nb-card-header">
                    <h2>Absences</h2>
                </div>

                <div class="nb-absence-list">
                    @if (recentAbsences is not null && recentAbsences.Any())
                    {
                        foreach (var item in recentAbsences)
                        {
                            <div class="nb-absence-row">
                                <div class="nb-summary-line"></div>
                                <div class="nb-summary-line short"></div>
                                <span class="nb-pill-success">Excused</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="nb-empty-state">No absence data available.</div>
                    }
                </div>
            </article>
        </div>
    </section>
</div>