@using System.ComponentModel.DataAnnotations
@using Entities.Enums
@model Web.ViewModels.PrincipalClassesViewModel

@{
    Layout = null;
    ViewData["Title"] = "Класове";

    var principalDisplayName = typeof(UserRole)
        .GetMember(nameof(UserRole.Principal))[0]
        .GetCustomAttributes(typeof(DisplayAttribute), false)
        .Cast<DisplayAttribute>()
        .FirstOrDefault()
        ?.GetName() ?? nameof(UserRole.Principal);
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Класове - NemeBook</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="nb-principal-body">
    <div class="nb-principal-shell">
        <aside class="nb-principal-sidebar" aria-label="Главна навигация">
            <a class="nb-principal-logo" asp-controller="Home" asp-action="Index">
                <span class="nb-principal-logo-mark">
                    <i class="bi bi-book-half" aria-hidden="true"></i>
                </span>
                <span>
                    <strong>NemeBook</strong>
                    <small>@principalDisplayName</small>
                </span>
            </a>

            <nav class="nb-principal-nav">
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-fill" aria-hidden="true"></i>
                    <span>Начало</span>
                </a>
                <a href="#">
                    <i class="bi bi-newspaper" aria-hidden="true"></i>
                    <span>Новини</span>
                </a>
                <a class="is-active" asp-controller="Grade" asp-action="AllClasses">
                    <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                    <span>Класове</span>
                </a>
                <a asp-controller="Chat" asp-action="Index">
                    <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
                    <span>Учителски чатове</span>
                </a>
                <a asp-controller="ProfileImport" asp-action="Index">
                    <i class="bi bi-upload" aria-hidden="true"></i>
                    <span>Импорт на профили</span>
                </a>
            </nav>

            <a class="nb-principal-user-card" asp-controller="Account" asp-action="Profile">
                <span class="nb-principal-user-avatar"></span>
                <span>
                    <strong>@(User.FindFirst("FullName")?.Value ?? "Директор")</strong>
                    <small>Директорски профил</small>
                </span>
            </a>
        </aside>

        <main class="nb-principal-main">
            <header class="nb-principal-topbar">
                <h1>Класове</h1>
                <partial name="_PrincipalStudentSearch" />
                <div class="nb-principal-top-actions">
                    <form asp-action="Logout" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button class="nb-principal-action-btn is-logout" type="submit">
                            <span>Изход</span>
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </header>

            <section class="nb-principal-content nb-classes-content" aria-label="Класове">
                <div class="nb-classes-tabs" aria-label="Випуск">
                    <span>Клас</span>
                    @foreach (var gradeNumber in Model.GradeNumbers)
                    {
                        <a class="@(gradeNumber == Model.SelectedGrade ? "is-active" : null)"
                           asp-controller="Grade"
                           asp-action="AllClasses"
                           asp-route-grade="@gradeNumber">
                            @gradeNumber
                        </a>
                    }
                </div>

                <section class="nb-classes-panel" aria-label="Паралелки">
                    <div class="nb-classes-grid">
                        @foreach (var schoolClass in Model.Classes)
                        {
                            <a class="nb-class-card"
                               asp-controller="ClassManagement"
                               asp-action="Students"
                               asp-route-classId="@schoolClass.Id">
                                <strong>@schoolClass.Name</strong>
                                <span class="nb-class-average @GetAverageClass(schoolClass.AverageGrade)">
                                    @if (schoolClass.AverageGrade.HasValue)
                                    {
                                        @schoolClass.AverageGrade.Value.ToString("0.00")
                                    }
                                </span>
                            </a>
                        }
                    </div>
                </section>
            </section>
        </main>
    </div>
</body>
</html>

@functions {
    private static string GetAverageClass(decimal? average)
    {
        if (!average.HasValue)
        {
            return "is-empty";
        }

        if (average.Value >= 5.50m)
        {
            return "is-high";
        }

        if (average.Value >= 4.50m)
        {
            return "is-medium";
        }

        return "is-low";
    }
}
