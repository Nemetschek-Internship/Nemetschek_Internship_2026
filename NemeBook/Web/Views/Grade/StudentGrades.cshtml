@model Entities.ViewModels.Grades.StudentGradesViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = $"Оценки - {Model.StudentName}";
}

@section Styles {
<style>
    .nb-student-grades-page {
        padding: 28px 34px 44px;
    }
    .nb-student-grades-header {
        margin-bottom: 18px;
    }
    .nb-student-grades-header h1 {
        margin: 0 0 6px;
        color: #20232a;
        font-size: 24px;
        font-weight: 950;
    }
    .nb-student-grades-header p {
        margin: 0;
        color: #80786f;
        font-size: 13px;
        font-weight: 800;
    }
    .nb-subject-grade-grid {
        display: grid;
        gap: 14px;
    }
    .nb-subject-grade-card {
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        padding: 16px;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
    }
    .nb-subject-grade-card header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }
    .nb-subject-grade-card h2 {
        margin: 0;
        color: #20232a;
        font-size: 17px;
        font-weight: 950;
    }
    .nb-subject-grade-card strong {
        color: #f97316;
        font-size: 15px;
        font-weight: 950;
    }
    .nb-grade-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .nb-grade-chip,
    .nb-popup-grade {
        min-width: 34px;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 999px;
        background: #fff1c8;
        color: #9a5b00;
        font: inherit;
        font-size: 13px;
        font-weight: 950;
    }
    .nb-grade-chip {
        width: 42px;
        height: 42px;
        min-width: 42px;
        min-height: 42px;
        padding: 0;
        border-radius: 50%;
        cursor: pointer;
        text-align: center;
        transition: transform 0.16s ease, box-shadow 0.16s ease;
    }
    .nb-grade-chip:hover,
    .nb-grade-chip:focus-visible {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(42, 35, 29, 0.1);
        outline: none;
    }
    .nb-grade-chip.is-high,
    .nb-popup-grade.is-high {
        background: #dff8e9;
        color: #159953;
    }
    .nb-grade-chip.is-low,
    .nb-popup-grade.is-low {
        background: #ffe0dc;
        color: #c23329;
    }
    .nb-popup-backdrop {
        position: fixed;
        inset: 0;
        z-index: 70;
        display: grid;
        place-items: center;
        padding: 24px;
        background: rgba(31, 35, 43, 0.42);
    }
    .nb-popup-backdrop[hidden] {
        display: none;
    }
    .nb-popup {
        width: min(470px, 100%);
        overflow: hidden;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 30px 80px rgba(31, 35, 43, 0.28);
    }
    .nb-popup-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border-bottom: 1px solid #eee7df;
    }
    .nb-popup-header h3 {
        margin: 0;
        color: #20232a;
        font-size: 16px;
        font-weight: 900;
    }
    .nb-popup-header p {
        margin: 3px 0 0;
        color: #9a938b;
        font-size: 12px;
        font-weight: 750;
    }
    .nb-popup-close {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border: 1px solid #f0ded0;
        border-radius: 50%;
        background: #fff8f1;
        color: #e95b0c;
        cursor: pointer;
    }
    .nb-popup-body {
        display: grid;
        gap: 12px;
        padding: 18px 20px 20px;
    }
    .nb-popup-grade {
        width: fit-content;
        padding: 3px 10px;
    }
    .nb-grade-detail-grid {
        display: grid;
        gap: 9px;
    }
    .nb-grade-detail-row {
        min-height: 38px;
        display: grid;
        grid-template-columns: 90px minmax(0, 1fr);
        align-items: center;
        gap: 12px;
        padding: 9px 10px;
        border-radius: 8px;
        background: #fbf7f2;
    }
    .nb-grade-detail-row span:first-child {
        color: #8d867c;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-grade-detail-row span:last-child {
        min-width: 0;
        overflow-wrap: anywhere;
        color: #242832;
        font-size: 13px;
        font-weight: 850;
    }
    .nb-grade-edit-form {
        display: grid;
        grid-template-columns: 110px minmax(0, 1fr);
        gap: 9px;
        padding: 12px;
        border-radius: 8px;
        background: #fbf7f2;
    }
    .nb-grade-edit-form label {
        display: grid;
        gap: 5px;
        color: #6f6962;
        font-size: 11px;
        font-weight: 900;
    }
    .nb-grade-edit-form input,
    .nb-grade-edit-form select,
    .nb-grade-edit-form textarea {
        min-height: 34px;
        border: 1px solid #eee3d8;
        border-radius: 7px;
        background: #fffaf5;
        color: #242832;
        font: inherit;
        font-size: 12px;
        font-weight: 800;
        padding: 6px 8px;
    }
    .nb-grade-edit-form textarea,
    .nb-grade-edit-actions,
    .nb-grade-edit-message {
        grid-column: 1 / -1;
    }
    .nb-grade-edit-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
    }
    .nb-grade-edit-actions button {
        min-height: 32px;
        border: 0;
        border-radius: 7px;
        color: #ffffff;
        font: inherit;
        font-size: 11px;
        font-weight: 950;
        cursor: pointer;
        padding: 0 12px;
    }
    .nb-grade-edit-actions .is-save {
        background: #f97316;
    }
    .nb-grade-edit-actions .is-danger {
        background: #dc2626;
    }
    .nb-grade-edit-message {
        min-height: 18px;
        color: #c23329;
        font-size: 11px;
        font-weight: 850;
    }
    body.nb-popup-open {
        overflow: hidden;
    }
    @@media (max-width: 640px) {
        .nb-student-grades-page {
            padding: 18px 16px 32px;
        }
        .nb-popup-backdrop {
            padding: 12px;
        }
        .nb-grade-detail-row {
            grid-template-columns: 1fr;
            gap: 4px;
        }
        .nb-grade-edit-form {
            grid-template-columns: 1fr;
        }
    }
</style>
}

<section class="nb-student-grades-page">
    <header class="nb-student-grades-header">
        <h1>@Model.StudentName</h1>
        <p>Клас @Model.ClassName · Общ успех @Model.OverallAverage.ToString("0.00")</p>
    </header>

    @if (Model.GradesBySubject.Count == 0)
    {
        <div class="nb-subject-grade-card">Няма въведени оценки.</div>
    }
    else
    {
        <div class="nb-subject-grade-grid">
            @foreach (var subject in Model.GradesBySubject.OrderBy(group => group.Key))
            {
                <article class="nb-subject-grade-card">
                    <header>
                        <h2>@subject.Key</h2>
                        <strong>@Model.AverageBySubject.GetValueOrDefault(subject.Key).ToString("0.00")</strong>
                    </header>
                    <div class="nb-grade-list">
                        @foreach (var grade in subject.Value.OrderByDescending(grade => grade.Date))
                        {
                            var modalId = $"grade-popup-{grade.Id:N}";
                            var displayGrade = GetDisplayedGrade(grade.Value).ToString();
                            var gradeClass = GetGradeClass(grade.Value);
                            var gradeTitle = $"{GetDisplayName(grade.Type)} · {grade.Date:dd.MM.yyyy}";

                            <button class="nb-grade-chip @gradeClass"
                                    type="button"
                                    data-nb-popup-open="@modalId"
                                    title="@gradeTitle"
                                    aria-label="Отвори детайли за оценка @displayGrade по @grade.SubjectName">
                                <span>@displayGrade</span>
                            </button>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@foreach (var subject in Model.GradesBySubject)
{
    foreach (var grade in subject.Value)
    {
        var modalId = $"grade-popup-{grade.Id:N}";
        var gradeClass = GetGradeClass(grade.Value);

        <div class="nb-popup-backdrop" data-nb-popup="@modalId" hidden>
            <section class="nb-popup" role="dialog" aria-modal="true" aria-labelledby="@($"{modalId}-title")" tabindex="-1">
                <header class="nb-popup-header">
                    <div>
                        <h3 id="@($"{modalId}-title")">@grade.SubjectName</h3>
                        <p>@GetDisplayName(grade.Type)</p>
                    </div>
                    <button class="nb-popup-close" type="button" data-nb-popup-close aria-label="Затвори">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>
                <div class="nb-popup-body">
                    <span class="nb-popup-grade @gradeClass">@grade.Value.ToString("0.00")</span>
                    <div class="nb-grade-detail-grid">
                        <div class="nb-grade-detail-row">
                            <span>Предмет</span>
                            <span>@grade.SubjectName</span>
                        </div>
                        <div class="nb-grade-detail-row">
                            <span>Учител</span>
                            <span>@grade.TeacherName</span>
                        </div>
                        <div class="nb-grade-detail-row">
                            <span>Тип</span>
                            <span>@GetDisplayName(grade.Type)</span>
                        </div>
                        <div class="nb-grade-detail-row">
                            <span>Дата</span>
                            <span>@grade.Date.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="nb-grade-detail-row">
                            <span>Бележка</span>
                            <span>@(string.IsNullOrWhiteSpace(grade.Note) ? "Няма бележка" : grade.Note)</span>
                        </div>
                    </div>
                    @if (grade.CanManage)
                    {
                        <form class="nb-grade-edit-form" data-grade-edit-form>
                            <input type="hidden" name="GradeId" value="@grade.Id" />
                            <label>
                                <span>Оценка</span>
                                <input name="Value" type="number" min="2" max="6" step="0.25" value="@grade.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" required />
                            </label>
                            <label>
                                <span>Тип</span>
                                <select name="Type" required>
                                    @foreach (var type in Enum.GetValues<Entities.Enums.GradeType>())
                                    {
                                        <option value="@((int)type)" selected="@(grade.Type == type)">@GetDisplayName(type)</option>
                                    }
                                </select>
                            </label>
                            <label>
                                <span>Бележка</span>
                                <textarea name="Note" maxlength="1000">@grade.Note</textarea>
                            </label>
                            <p class="nb-grade-edit-message" data-grade-edit-message aria-live="polite"></p>
                            <div class="nb-grade-edit-actions">
                                <button class="is-save" type="submit">Запази</button>
                                <button class="is-danger" type="button" data-grade-delete="@grade.Id">Изтрий</button>
                            </div>
                        </form>
                    }
                </div>
            </section>
        </div>
    }
}

@section Scripts {
<script>
(() => {
const triggers = document.querySelectorAll("[data-nb-popup-open]");
const popups = document.querySelectorAll("[data-nb-popup]");
let activeTrigger = null;

const closePopup = (popup) => {
    if (!popup) {
        return;
    }

    popup.hidden = true;
    document.body.classList.remove("nb-popup-open");

    if (activeTrigger) {
        activeTrigger.focus();
        activeTrigger = null;
    }
};

const openPopup = (id, trigger) => {
    const popup = document.querySelector(`[data-nb-popup="${id}"]`);
    if (!popup) {
        return;
    }

    activeTrigger = trigger;
    popup.hidden = false;
    document.body.classList.add("nb-popup-open");
    popup.querySelector(".nb-popup")?.focus();
};

triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
        openPopup(trigger.dataset.nbPopupOpen, trigger);
    });
});

popups.forEach((popup) => {
    popup.addEventListener("click", (event) => {
        if (event.target === popup || event.target.closest("[data-nb-popup-close]")) {
            closePopup(popup);
        }
    });
});

const requestedGradeId = new URLSearchParams(window.location.search).get("gradeId");
if (requestedGradeId) {
    openPopup(`grade-popup-${requestedGradeId.replaceAll("-", "")}`, null);
}

document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
        closePopup(document.querySelector("[data-nb-popup]:not([hidden])"));
    }
});

const showFormError = (form, message) => {
    const target = form.querySelector("[data-grade-edit-message]");
    if (target) {
        target.textContent = message || "Възникна грешка.";
    }
};

document.querySelectorAll("[data-grade-edit-form]").forEach((form) => {
    form.addEventListener("submit", async (event) => {
        event.preventDefault();
        showFormError(form, "");

        const formData = new FormData(form);
        const response = await fetch("@Url.Action("UpdateGrade", "Grade")", {
            method: "PUT",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                gradeId: formData.get("GradeId"),
                value: Number(formData.get("Value")),
                type: Number(formData.get("Type")),
                note: formData.get("Note") || ""
            })
        });

        if (response.ok) {
            window.location.reload();
            return;
        }

        const payload = await response.json().catch(() => ({}));
        showFormError(form, payload.error || "Оценката не беше запазена.");
    });
});

document.querySelectorAll("[data-grade-delete]").forEach((button) => {
    button.addEventListener("click", async () => {
        if (!confirm("Сигурни ли сте, че искате да изтриете тази оценка?")) {
            return;
        }

        const response = await fetch(`@Url.Action("DeleteGrade", "Grade")?gradeId=${button.dataset.gradeDelete}`, {
            method: "DELETE"
        });

        if (response.ok) {
            window.location.reload();
            return;
        }

        const form = button.closest("[data-grade-edit-form]");
        const payload = await response.json().catch(() => ({}));
        if (form) {
            showFormError(form, payload.error || "Оценката не беше изтрита.");
        }
    });
});
})();
</script>
}

@functions {
    private static int GetDisplayedGrade(decimal value)
    {
        if (value < 3)
        {
            return 2;
        }

        return Math.Clamp((int)Math.Floor(value + 0.5m), 3, 6);
    }

    private static string GetGradeClass(decimal value)
    {
        var display = GetDisplayedGrade(value);
        return display >= 5 ? "is-high" : display <= 3 ? "is-low" : string.Empty;
    }

    private static string GetDisplayName(Enum value)
    {
        var member = value.GetType().GetMember(value.ToString()).FirstOrDefault();
        var display = member?
            .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
            .OfType<System.ComponentModel.DataAnnotations.DisplayAttribute>()
            .FirstOrDefault();

        return display?.Name ?? value.ToString();
    }
}
