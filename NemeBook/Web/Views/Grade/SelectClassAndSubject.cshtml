@model Web.Controllers.SelectClassSubjectViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Избор на клас и предмет";
}

@section Styles {
<style>
    .nb-grade-picker-page { padding: 28px 34px 44px; }
    .nb-grade-picker-panel { max-width: 720px; border: 1px solid #eee7df; border-radius: 8px; background: #fff; padding: 22px; box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05); }
    .nb-grade-picker-panel h1 { margin: 0 0 8px; color: #20232a; font-size: 24px; font-weight: 950; }
    .nb-grade-picker-panel p { margin: 0 0 18px; color: #80786f; font-size: 13px; font-weight: 800; }
    .nb-grade-picker-form { display: grid; gap: 14px; }
    .nb-grade-picker-form label { display: grid; gap: 7px; color: #6f6962; font-size: 11px; font-weight: 900; }
    .nb-grade-picker-form select { min-height: 42px; border: 1px solid #eee3d8; border-radius: 7px; background: #fffaf5; color: #242832; font: inherit; font-weight: 800; padding: 8px 10px; }
    .nb-grade-picker-form button { justify-self: start; min-height: 38px; border: 0; border-radius: 7px; padding: 0 16px; background: #f97316; color: #fff; font: inherit; font-size: 12px; font-weight: 950; cursor: pointer; }
</style>
}

<section class="nb-grade-picker-page">
    <div class="nb-grade-picker-panel">
        <h1>Оценки по клас и предмет</h1>
        <p>@Model.TeacherName</p>

        @if (Model.AvailableClassSubjects.Count == 0)
        {
            <p>Няма назначени предмети.</p>
        }
        else
        {
            <form class="nb-grade-picker-form" method="post" asp-controller="Grade" asp-action="SelectClassAndSubject">
                <label>
                    Клас и предмет
                    <select name="classSubjectId" required>
                        @foreach (var option in Model.AvailableClassSubjects)
                        {
                            <option value="@option.ClassSubjectId">Клас @option.ClassName - @option.SubjectName</option>
                        }
                    </select>
                </label>
                <button type="submit">Отвори</button>
            </form>
        }
    </div>
</section>
