{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=NemeBook;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "${SMTP_USERNAME}",
    "SmtpPassword": "${SMTP_PASSWORD}",
    "FromEmail": "${SMTP_USERNAME}",
    "FromName": "NemeBook"
  },
  "RegistrationEmail": {
    "BaseUrl": "${REG_BASE_URL}",
    "SetPasswordPath": "/Account/SetPassword",
    "ParentSignUpPath": "/Account/ParentSignUp"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}